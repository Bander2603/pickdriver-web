@page "/races"
@using System.Globalization
@inject ApiClient ApiClient

<PageTitle>Carreras</PageTitle>

<div class="races-header">
    <div>
        <h1>Carreras</h1>
        <p class="races-subtitle text-muted">Calendario de la temporada.</p>
    </div>
</div>

@if (isLoading)
{
    <p><em>Cargando carreras...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning" role="alert">@errorMessage</div>
}
else if (races.Count == 0)
{
    <p class="text-muted">Sin carreras disponibles.</p>
}
else
{
    <div class="race-grid">
        @for (var i = 0; i < races.Count; i++)
        {
            var race = races[i];
            var isFeatured = i == 0;
            <article class="race-card @(isFeatured ? "race-card--featured" : string.Empty)">
                <div class="race-card__top">
                    <span class="race-card__round">Round @race.Round</span>
                    <span class="race-card__date">@FormatRaceDate(race.RaceTime)</span>
                </div>
                <h2 class="race-card__title">@race.Name</h2>
                <p class="race-card__circuit">@race.CircuitName</p>
                <div class="race-card__footer">
                    <span class="race-card__status">@GetStatusLabel(race)</span>
                </div>
            </article>
        }
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private readonly List<Race> races = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await ApiClient.GetAsync<List<Race>>("races");
        if (result.Success && result.Data is not null)
        {
            races.AddRange(result.Data.OrderBy(race => race.Round));
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "No se pudieron cargar las carreras.";
        }

        isLoading = false;
    }

    private static string FormatRaceDate(DateTimeOffset? date)
    {
        if (!date.HasValue)
        {
            return "Por confirmar";
        }

        return date.Value.ToLocalTime().ToString("dd MMM yyyy", CultureInfo.InvariantCulture);
    }

    private static string GetStatusLabel(Race race)
    {
        return race.RaceTime.HasValue ? "Fecha confirmada" : "Fecha por confirmar";
    }
}
