@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Iniciar sesion</PageTitle>

<h1>Iniciar sesion</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<EditForm Model="model" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="login-email">Email</label>
        <InputText id="login-email" class="form-control" type="email" autocomplete="username" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="login-password">Password</label>
        <InputText id="login-password" class="form-control" type="password" autocomplete="current-password" @bind-Value="model.Password" />
        <ValidationMessage For="() => model.Password" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
        @(isSubmitting ? "Ingresando..." : "Ingresar")
    </button>
</EditForm>

<p class="mt-3">
    No tienes cuenta? <a href="register">Crear cuenta</a>
</p>

@code {
    private readonly LoginFormModel model = new();
    private bool isSubmitting;
    private string? errorMessage;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.LoginAsync(new LoginRequest
        {
            Email = model.Email.Trim(),
            Password = model.Password
        });

        isSubmitting = false;

        if (result.Success)
        {
            var target = "/";
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
            {
                target = ReturnUrl;
            }

            NavigationManager.NavigateTo(target);
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo iniciar sesion.";
    }

    private sealed class LoginFormModel
    {
        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La password es obligatoria.")]
        public string Password { get; set; } = string.Empty;
    }
}
