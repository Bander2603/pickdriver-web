@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IOptions<GoogleAuthOptions> GoogleOptions
@inject EmailCooldownService EmailCooldownService

<PageTitle>Pick Driver</PageTitle>

<h1>@Text["Iniciar sesion"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

<EditForm Model="model" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="login-email">Email</label>
        <InputText id="login-email" class="form-control" type="email" autocomplete="username" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="login-password">@Text["Password"]</label>
        <InputText id="login-password" class="form-control" type="password" autocomplete="current-password" @bind-Value="model.Password" />
        <ValidationMessage For="() => model.Password" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
        @(isSubmitting ? Text["Ingresando..."] : Text["Ingresar"])
    </button>

    <p class="mt-3 mb-0">
        <a href="forgot-password">@Text["Olvide mi password"]</a>
    </p>
</EditForm>

@if (showResendVerification)
{
    <div class="alert alert-warning mt-3" role="alert">
        @Text["Tu cuenta aun no esta verificada."]
        <div class="mt-2">
            <button class="btn btn-sm btn-outline-secondary" type="button" disabled="@(isResendingVerification || IsVerificationCooldownActive)" @onclick="HandleResendVerificationAsync">
                @GetResendVerificationButtonLabel()
            </button>
        </div>
    </div>
}

<div class="auth-divider">o</div>

<div class="google-auth">
    @if (IsGoogleEnabled)
    {
        <div id="@GoogleButtonId"></div>
    }
    else
    {
        <button class="btn btn-outline-light" type="button" disabled>
            @Text["Iniciar sesion con Google"]
        </button>
    }
</div>

@if (!IsGoogleEnabled)
{
    <small class="text-muted d-block mt-2">
        @Text["Login con Google no esta configurado."]
    </small>
}

<p class="mt-3">
    @Text["No tienes cuenta?"] <a href="register">@Text["Crear cuenta"]</a>
</p>

<div class="login-mobile-apps">
    <div class="login-mobile-apps__panel">
        <MobileAppsPanel />
    </div>
</div>

@code {
    private readonly LoginFormModel model = new();
    private bool isSubmitting;
    private bool isResendingVerification;
    private bool showResendVerification;
    private string? errorMessage;
    private string? infoMessage;
    private DotNetObjectReference<Login>? googleRef;
    private DateTimeOffset? verificationCooldownEndsAt;
    private Timer? cooldownTimer;
    private bool disposed;

    private const string GoogleButtonId = "google-login-button";
    private bool IsGoogleEnabled => !string.IsNullOrWhiteSpace(GoogleOptions.Value.ClientId);
    private int VerificationCooldownRemainingSeconds => EmailCooldownService.GetRemainingSeconds(verificationCooldownEndsAt);
    private bool IsVerificationCooldownActive => VerificationCooldownRemainingSeconds > 0;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        errorMessage = null;
        infoMessage = null;
        showResendVerification = false;
        isSubmitting = true;

        var result = await AuthService.LoginAsync(new LoginRequest
        {
            Email = model.Email.Trim(),
            Password = model.Password
        });

        isSubmitting = false;

        if (result.Success)
        {
            var target = "/";
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
            {
                target = ReturnUrl;
            }

            NavigationManager.NavigateTo(target);
            return;
        }

        showResendVerification = result.StatusCode == 403;
        errorMessage = Text.TranslateApiMessage(result.ErrorMessage, "No se pudo iniciar sesion.");
    }

    private async Task HandleResendVerificationAsync()
    {
        if (IsVerificationCooldownActive)
        {
            infoMessage = Text.Format("Espera {0} para volver a reenviar la verificacion.", EmailCooldownService.Format(VerificationCooldownRemainingSeconds));
            return;
        }

        var email = model.Email.Trim();
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = Text["Indica tu email para reenviar la verificacion."];
            return;
        }

        errorMessage = null;
        infoMessage = null;
        isResendingVerification = true;

        var result = await AuthService.ResendVerificationAsync(new ResendVerificationRequest
        {
            Email = email
        });

        isResendingVerification = false;

        if (result.Success)
        {
            verificationCooldownEndsAt = await EmailCooldownService.StartAsync(EmailCooldownType.ResendVerification);
            infoMessage = Text.TranslateApiMessage(result.Data?.Message, "Si la cuenta existe y esta pendiente, se envio un email de verificacion.");
            return;
        }

        errorMessage = Text.TranslateApiMessage(result.ErrorMessage, "No se pudo reenviar el email de verificacion.");
    }

    private sealed class LoginFormModel
    {
        [LocalizedRequired("El email es obligatorio.")]
        [LocalizedEmailAddress("Email invalido.")]
        public string Email { get; set; } = string.Empty;

        [LocalizedRequired("La password es obligatoria.")]
        public string Password { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        verificationCooldownEndsAt = await EmailCooldownService.GetEndsAtAsync(EmailCooldownType.ResendVerification);
        StartCooldownTimer();

        if (IsGoogleEnabled)
        {
            googleRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.initialize", GoogleOptions.Value.ClientId, googleRef);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.renderButton", GoogleButtonId, new
            {
                theme = "outline",
                size = "large",
                text = "signin_with",
                shape = "pill"
            });
        }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string idToken)
    {
        errorMessage = null;
        infoMessage = null;
        showResendVerification = false;

        var result = await AuthService.GoogleLoginAsync(new GoogleAuthRequest
        {
            IdToken = idToken
        });

        if (result.Success)
        {
            var target = "/";
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
            {
                target = ReturnUrl;
            }

            NavigationManager.NavigateTo(target);
            return;
        }

        errorMessage = Text.TranslateApiMessage(result.ErrorMessage, "No se pudo iniciar sesion con Google.");
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        if (googleRef is not null)
        {
            googleRef.Dispose();
        }

        cooldownTimer?.Dispose();
        await Task.CompletedTask;
    }

    private string GetResendVerificationButtonLabel()
    {
        if (isResendingVerification)
        {
            return Text["Reenviando..."];
        }

        if (IsVerificationCooldownActive)
        {
            return Text.Format("Reenviar en {0}", EmailCooldownService.Format(VerificationCooldownRemainingSeconds));
        }

        return Text["Reenviar email de verificacion"];
    }

    private void StartCooldownTimer()
    {
        cooldownTimer?.Dispose();
        cooldownTimer = new Timer(_ => _ = HandleCooldownTickAsync(), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task HandleCooldownTickAsync()
    {
        if (disposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(async () =>
            {
                if (disposed || !verificationCooldownEndsAt.HasValue)
                {
                    return;
                }

                if (VerificationCooldownRemainingSeconds == 0 && verificationCooldownEndsAt.HasValue)
                {
                    verificationCooldownEndsAt = null;
                    await EmailCooldownService.ClearAsync(EmailCooldownType.ResendVerification);
                }

                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }
}
