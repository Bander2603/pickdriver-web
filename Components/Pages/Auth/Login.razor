@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IOptions<GoogleAuthOptions> GoogleOptions

<PageTitle>Pick Driver</PageTitle>

<h1>Iniciar sesion</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

<EditForm Model="model" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="login-email">Email</label>
        <InputText id="login-email" class="form-control" type="email" autocomplete="username" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="login-password">Password</label>
        <InputText id="login-password" class="form-control" type="password" autocomplete="current-password" @bind-Value="model.Password" />
        <ValidationMessage For="() => model.Password" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
        @(isSubmitting ? "Ingresando..." : "Ingresar")
    </button>

    <p class="mt-3 mb-0">
        <a href="forgot-password">Olvide mi password</a>
    </p>
</EditForm>

@if (showResendVerification)
{
    <div class="alert alert-warning mt-3" role="alert">
        Tu cuenta aun no esta verificada.
        <div class="mt-2">
            <button class="btn btn-sm btn-outline-secondary" type="button" disabled="@isResendingVerification" @onclick="HandleResendVerificationAsync">
                @(isResendingVerification ? "Reenviando..." : "Reenviar email de verificacion")
            </button>
        </div>
    </div>
}

<div class="auth-divider">o</div>

<div class="google-auth">
    @if (IsGoogleEnabled)
    {
        <div id="@GoogleButtonId"></div>
    }
    else
    {
        <button class="btn btn-outline-light" type="button" disabled>
            Iniciar sesion con Google
        </button>
    }
</div>

@if (!IsGoogleEnabled)
{
    <small class="text-muted d-block mt-2">
        Login con Google no esta configurado.
    </small>
}

<p class="mt-3">
    No tienes cuenta? <a href="register">Crear cuenta</a>
</p>

@code {
    private readonly LoginFormModel model = new();
    private bool isSubmitting;
    private bool isResendingVerification;
    private bool showResendVerification;
    private string? errorMessage;
    private string? infoMessage;
    private DotNetObjectReference<Login>? googleRef;

    private const string GoogleButtonId = "google-login-button";
    private bool IsGoogleEnabled => !string.IsNullOrWhiteSpace(GoogleOptions.Value.ClientId);

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        errorMessage = null;
        infoMessage = null;
        showResendVerification = false;
        isSubmitting = true;

        var result = await AuthService.LoginAsync(new LoginRequest
        {
            Email = model.Email.Trim(),
            Password = model.Password
        });

        isSubmitting = false;

        if (result.Success)
        {
            var target = "/";
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
            {
                target = ReturnUrl;
            }

            NavigationManager.NavigateTo(target);
            return;
        }

        showResendVerification = result.StatusCode == 403;
        errorMessage = result.ErrorMessage ?? "No se pudo iniciar sesion.";
    }

    private async Task HandleResendVerificationAsync()
    {
        var email = model.Email.Trim();
        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Indica tu email para reenviar la verificacion.";
            return;
        }

        errorMessage = null;
        infoMessage = null;
        isResendingVerification = true;

        var result = await AuthService.ResendVerificationAsync(new ResendVerificationRequest
        {
            Email = email
        });

        isResendingVerification = false;

        if (result.Success)
        {
            infoMessage = string.IsNullOrWhiteSpace(result.Data?.Message)
                ? "Si la cuenta existe y esta pendiente, se envio un email de verificacion."
                : result.Data.Message;
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo reenviar el email de verificacion.";
    }

    private sealed class LoginFormModel
    {
        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La password es obligatoria.")]
        public string Password { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsGoogleEnabled)
        {
            googleRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.initialize", GoogleOptions.Value.ClientId, googleRef);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.renderButton", GoogleButtonId, new
            {
                theme = "outline",
                size = "large",
                text = "signin_with",
                shape = "pill"
            });
        }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string idToken)
    {
        errorMessage = null;
        infoMessage = null;
        showResendVerification = false;

        var result = await AuthService.GoogleLoginAsync(new GoogleAuthRequest
        {
            IdToken = idToken
        });

        if (result.Success)
        {
            var target = "/";
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
            {
                target = ReturnUrl;
            }

            NavigationManager.NavigateTo(target);
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo iniciar sesion con Google.";
    }

    public async ValueTask DisposeAsync()
    {
        if (googleRef is not null)
        {
            googleRef.Dispose();
        }

        await Task.CompletedTask;
    }
}
