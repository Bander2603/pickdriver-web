@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IOptions<GoogleAuthOptions> GoogleOptions
@inject EmailCooldownService EmailCooldownService

<PageTitle>Pick Driver</PageTitle>

<h1>Crear cuenta</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (isSuccess)
{
    <div class="alert alert-success" role="alert">
        Registro completado. Revisa tu email para verificar la cuenta antes de iniciar sesion.
    </div>

    @if (!verificationEmailSent)
    {
        <div class="alert alert-warning" role="alert">
            No se pudo confirmar el envio del email de verificacion. Puedes solicitarlo de nuevo.
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-outline-secondary" type="button" disabled="@(isResendingVerification || IsVerificationCooldownActive)" @onclick="HandleResendVerificationAsync">
            @GetResendVerificationButtonLabel()
        </button>
        <a class="btn btn-primary" href="login">Iniciar sesion</a>
    </div>
}
else
{
    <EditForm Model="model" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="register-username">Usuario</label>
            <InputText id="register-username" class="form-control" autocomplete="username" @bind-Value="model.Username" />
            <ValidationMessage For="() => model.Username" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-email">Email</label>
            <InputText id="register-email" class="form-control" type="email" autocomplete="email" @bind-Value="model.Email" />
            <ValidationMessage For="() => model.Email" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-password">Password</label>
            <InputText id="register-password" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.Password" />
            <ValidationMessage For="() => model.Password" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-confirm">Confirmar password</label>
            <InputText id="register-confirm" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.ConfirmPassword" />
            <ValidationMessage For="() => model.ConfirmPassword" />
        </div>

        <div class="auth-actions">
            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
                @(isSubmitting ? "Creando..." : "Crear cuenta")
            </button>
        </div>
    </EditForm>

    <div class="auth-divider">o</div>

    <div class="google-auth">
        @if (IsGoogleEnabled)
        {
            <div class="google-auth__wrap">
                <div id="@GoogleButtonId"></div>
            </div>
        }
        else
        {
            <button class="btn btn-outline-light" type="button" disabled>
                Registrarme con Google
            </button>
        }
    </div>

    @if (!IsGoogleEnabled)
    {
        <small class="text-muted d-block mt-2">
            Login con Google no esta configurado.
        </small>
    }

    <p class="mt-3">
        Ya tienes cuenta? <a href="login">Iniciar sesion</a>
    </p>
}

@code {
    private readonly RegisterFormModel model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private bool isResendingVerification;
    private bool verificationEmailSent;
    private string registeredEmail = string.Empty;
    private string? errorMessage;
    private string? infoMessage;
    private DotNetObjectReference<Register>? googleRef;
    private DateTimeOffset? verificationCooldownEndsAt;
    private Timer? cooldownTimer;
    private bool disposed;

    private const string GoogleButtonId = "google-register-button";
    private bool IsGoogleEnabled => !string.IsNullOrWhiteSpace(GoogleOptions.Value.ClientId);
    private int VerificationCooldownRemainingSeconds => EmailCooldownService.GetRemainingSeconds(verificationCooldownEndsAt);
    private bool IsVerificationCooldownActive => VerificationCooldownRemainingSeconds > 0;

    private async Task HandleRegister()
    {
        errorMessage = null;
        infoMessage = null;
        isSubmitting = true;

        var result = await AuthService.RegisterAsync(new RegisterRequest
        {
            Username = model.Username.Trim(),
            Email = model.Email.Trim(),
            Password = model.Password
        });

        isSubmitting = false;

        if (result.Success && result.Data is not null)
        {
            isSuccess = true;
            registeredEmail = model.Email.Trim();
            verificationEmailSent = result.Data.VerificationEmailSent;
            if (verificationEmailSent)
            {
                verificationCooldownEndsAt = await EmailCooldownService.StartAsync(EmailCooldownType.ResendVerification);
            }
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo completar el registro.";
    }

    private async Task HandleResendVerificationAsync()
    {
        if (IsVerificationCooldownActive)
        {
            infoMessage = $"Espera {EmailCooldownService.Format(VerificationCooldownRemainingSeconds)} para volver a reenviar la verificacion.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registeredEmail))
        {
            return;
        }

        errorMessage = null;
        infoMessage = null;
        isResendingVerification = true;

        var result = await AuthService.ResendVerificationAsync(new ResendVerificationRequest
        {
            Email = registeredEmail
        });

        isResendingVerification = false;

        if (result.Success)
        {
            verificationCooldownEndsAt = await EmailCooldownService.StartAsync(EmailCooldownType.ResendVerification);
            infoMessage = string.IsNullOrWhiteSpace(result.Data?.Message)
                ? "Si la cuenta existe y esta pendiente, se envio otro email de verificacion."
                : result.Data.Message;
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo reenviar el email de verificacion.";
    }

    private sealed class RegisterFormModel
    {
        [Required(ErrorMessage = "El usuario es obligatorio.")]
        [StringLength(50, MinimumLength = 3, ErrorMessage = "El usuario debe tener entre 3 y 50 caracteres.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La password es obligatoria.")]
        [MinLength(8, ErrorMessage = "La password debe tener al menos 8 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "Las passwords no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        verificationCooldownEndsAt = await EmailCooldownService.GetEndsAtAsync(EmailCooldownType.ResendVerification);
        StartCooldownTimer();

        if (IsGoogleEnabled)
        {
            googleRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.initialize", GoogleOptions.Value.ClientId, googleRef);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.renderButton", GoogleButtonId, new
            {
                theme = "outline",
                size = "large",
                text = "signup_with",
                shape = "pill"
            });
        }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string idToken)
    {
        errorMessage = null;

        var result = await AuthService.GoogleLoginAsync(new GoogleAuthRequest
        {
            IdToken = idToken
        });

        if (result.Success)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo registrar con Google.";
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        if (googleRef is not null)
        {
            googleRef.Dispose();
        }

        cooldownTimer?.Dispose();
        await Task.CompletedTask;
    }

    private string GetResendVerificationButtonLabel()
    {
        if (isResendingVerification)
        {
            return "Reenviando...";
        }

        if (IsVerificationCooldownActive)
        {
            return $"Reenviar en {EmailCooldownService.Format(VerificationCooldownRemainingSeconds)}";
        }

        return "Reenviar verificacion";
    }

    private void StartCooldownTimer()
    {
        cooldownTimer?.Dispose();
        cooldownTimer = new Timer(_ => _ = HandleCooldownTickAsync(), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task HandleCooldownTickAsync()
    {
        if (disposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(async () =>
            {
                if (disposed || !verificationCooldownEndsAt.HasValue)
                {
                    return;
                }

                if (VerificationCooldownRemainingSeconds == 0 && verificationCooldownEndsAt.HasValue)
                {
                    verificationCooldownEndsAt = null;
                    await EmailCooldownService.ClearAsync(EmailCooldownType.ResendVerification);
                }

                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }
}
