@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Options
@implements IAsyncDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IOptions<GoogleAuthOptions> GoogleOptions

<PageTitle>Pick Driver</PageTitle>

<h1>Crear cuenta</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (isSuccess)
{
    <div class="alert alert-success" role="alert">
        Registro completado. Ya puedes iniciar sesion.
    </div>

    <div class="d-flex gap-2 mt-3">
        <a class="btn btn-primary" href="login">Iniciar sesion</a>
    </div>
}
else
{
    <EditForm Model="model" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="register-username">Usuario</label>
            <InputText id="register-username" class="form-control" autocomplete="username" @bind-Value="model.Username" />
            <ValidationMessage For="() => model.Username" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-email">Email</label>
            <InputText id="register-email" class="form-control" type="email" autocomplete="email" @bind-Value="model.Email" />
            <ValidationMessage For="() => model.Email" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-password">Password</label>
            <InputText id="register-password" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.Password" />
            <ValidationMessage For="() => model.Password" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-invite">Codigo de invitacion (solo registro con email)</label>
            <InputText id="register-invite" class="form-control" autocomplete="off" @bind-Value="model.InviteCode" />
            <ValidationMessage For="() => model.InviteCode" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="register-confirm">Confirmar password</label>
            <InputText id="register-confirm" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.ConfirmPassword" />
            <ValidationMessage For="() => model.ConfirmPassword" />
        </div>

        <div class="auth-actions">
            <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
                @(isSubmitting ? "Creando..." : "Registrarme con codigo")
            </button>
        </div>
    </EditForm>

    <div class="auth-divider">o</div>

    <div class="google-auth">
        @if (IsGoogleEnabled)
        {
            <div class="google-auth__wrap">
                <div id="@GoogleButtonId"></div>
            </div>
        }
        else
        {
            <button class="btn btn-outline-light" type="button" disabled>
                Registrarme con Google
            </button>
        }
    </div>

    @if (!IsGoogleEnabled)
    {
        <small class="text-muted d-block mt-2">
            Login con Google no esta configurado.
        </small>
    }
}

@code {
    private readonly RegisterFormModel model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private string? errorMessage;
    private DotNetObjectReference<Register>? googleRef;

    private const string GoogleButtonId = "google-register-button";
    private bool IsGoogleEnabled => !string.IsNullOrWhiteSpace(GoogleOptions.Value.ClientId);

    private async Task HandleRegister()
    {
        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.RegisterAsync(new RegisterRequest
        {
            Username = model.Username.Trim(),
            Email = model.Email.Trim(),
            Password = model.Password,
            InviteCode = model.InviteCode.Trim()
        });

        isSubmitting = false;

        if (result.Success && result.Data is not null)
        {
            isSuccess = true;
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo completar el registro.";
    }

    private sealed class RegisterFormModel
    {
        [Required(ErrorMessage = "El usuario es obligatorio.")]
        [StringLength(50, MinimumLength = 3, ErrorMessage = "El usuario debe tener entre 3 y 50 caracteres.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La password es obligatoria.")]
        [MinLength(8, ErrorMessage = "La password debe tener al menos 8 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "El codigo de invitacion es obligatorio.")]
        public string InviteCode { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "Las passwords no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsGoogleEnabled)
        {
            googleRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.initialize", GoogleOptions.Value.ClientId, googleRef);
            await JSRuntime.InvokeVoidAsync("pickdriverGoogleAuth.renderButton", GoogleButtonId, new
            {
                theme = "outline",
                size = "large",
                text = "signup_with",
                shape = "pill"
            });
        }
    }

    [JSInvokable]
    public async Task OnGoogleCredential(string idToken)
    {
        errorMessage = null;

        var result = await AuthService.GoogleLoginAsync(new GoogleAuthRequest
        {
            IdToken = idToken
        });

        if (result.Success)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo registrarte con Google.";
    }

    public async ValueTask DisposeAsync()
    {
        if (googleRef is not null)
        {
            googleRef.Dispose();
        }

        await Task.CompletedTask;
    }
}
