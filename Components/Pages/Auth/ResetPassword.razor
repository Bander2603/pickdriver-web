@page "/reset-password"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject AuthService AuthService

<PageTitle>Pick Driver</PageTitle>

<h1>Restablecer password</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (isSuccess)
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>

    <p class="mt-3 mb-0">
        <a href="login">Iniciar sesion</a>
    </p>
}
else if (!HasToken)
{
    <div class="alert alert-warning" role="alert">
        El enlace de recuperacion no es valido o no contiene token.
    </div>
}
else
{
    <p class="text-muted">Introduce tu nueva password para completar el cambio.</p>

    <EditForm Model="model" OnValidSubmit="HandleSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="reset-password">Nueva password</label>
            <InputText id="reset-password" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.NewPassword" />
            <ValidationMessage For="() => model.NewPassword" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="reset-password-confirm">Confirmar password</label>
            <InputText id="reset-password-confirm" class="form-control" type="password" autocomplete="new-password" @bind-Value="model.ConfirmPassword" />
            <ValidationMessage For="() => model.ConfirmPassword" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
            @(isSubmitting ? "Guardando..." : "Actualizar password")
        </button>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private readonly ResetPasswordFormModel model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private string? token;
    private string? errorMessage;
    private string successMessage = "Password actualizada correctamente.";

    private bool HasToken => !string.IsNullOrWhiteSpace(token);

    protected override void OnParametersSet()
    {
        token = Token?.Trim();
    }

    private async Task HandleSubmitAsync()
    {
        if (!HasToken)
        {
            errorMessage = "El enlace de recuperacion no es valido o no contiene token.";
            return;
        }

        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.ResetPasswordAsync(new ResetPasswordRequest
        {
            Token = token!,
            NewPassword = model.NewPassword
        });

        isSubmitting = false;

        if (result.Success)
        {
            isSuccess = true;
            if (!string.IsNullOrWhiteSpace(result.Data?.Message))
            {
                successMessage = result.Data.Message;
            }

            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo restablecer la password.";
    }

    private sealed class ResetPasswordFormModel
    {
        [Required(ErrorMessage = "La nueva password es obligatoria.")]
        [MinLength(8, ErrorMessage = "La password debe tener al menos 8 caracteres.")]
        public string NewPassword { get; set; } = string.Empty;

        [Compare(nameof(NewPassword), ErrorMessage = "Las passwords no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
