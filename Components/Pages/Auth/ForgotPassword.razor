@page "/forgot-password"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject AuthService AuthService

<PageTitle>Pick Driver</PageTitle>

<h1>Recuperar password</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (isSuccess)
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>

    <p class="mt-3 mb-0">
        <a href="login">Volver al login</a>
    </p>
}
else
{
    <p class="text-muted">Introduce tu email y te enviaremos instrucciones para restablecer tu password.</p>

    <EditForm Model="model" OnValidSubmit="HandleSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="forgot-email">Email</label>
            <InputText id="forgot-email" class="form-control" type="email" autocomplete="email" @bind-Value="model.Email" />
            <ValidationMessage For="() => model.Email" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
            @(isSubmitting ? "Enviando..." : "Enviar instrucciones")
        </button>
    </EditForm>

    <p class="mt-3 mb-0">
        <a href="login">Volver al login</a>
    </p>
}

@code {
    private readonly ForgotPasswordModel model = new();
    private bool isSubmitting;
    private bool isSuccess;
    private string? errorMessage;
    private string successMessage = "Si la cuenta existe, te hemos enviado un email con instrucciones.";

    private async Task HandleSubmitAsync()
    {
        errorMessage = null;
        isSubmitting = true;

        var result = await AuthService.ForgotPasswordAsync(new ForgotPasswordRequest
        {
            Email = model.Email.Trim()
        });

        isSubmitting = false;

        if (result.Success)
        {
            isSuccess = true;
            if (!string.IsNullOrWhiteSpace(result.Data?.Message))
            {
                successMessage = result.Data.Message;
            }

            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo iniciar la recuperacion de password.";
    }

    private sealed class ForgotPasswordModel
    {
        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;
    }
}
