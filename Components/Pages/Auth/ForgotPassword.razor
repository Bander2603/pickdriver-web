@page "/forgot-password"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@implements IDisposable
@inject AuthService AuthService
@inject EmailCooldownService EmailCooldownService

<PageTitle>Pick Driver</PageTitle>

<h1>Recuperar password</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>
}

<p class="text-muted">Introduce tu email y te enviaremos instrucciones para restablecer tu password.</p>

<EditForm Model="model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="forgot-email">Email</label>
        <InputText id="forgot-email" class="form-control" type="email" autocomplete="email" @bind-Value="model.Email" />
        <ValidationMessage For="() => model.Email" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@(isSubmitting || IsCooldownActive)">
        @GetSubmitButtonLabel()
    </button>
</EditForm>

<p class="mt-3 mb-0">
    <a href="login">Volver al login</a>
</p>

@code {
    private readonly ForgotPasswordModel model = new();
    private bool isSubmitting;
    private DateTimeOffset? cooldownEndsAt;
    private Timer? cooldownTimer;
    private bool disposed;
    private string? errorMessage;
    private string? successMessage;

    private int CooldownRemainingSeconds => EmailCooldownService.GetRemainingSeconds(cooldownEndsAt);
    private bool IsCooldownActive => CooldownRemainingSeconds > 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        cooldownEndsAt = await EmailCooldownService.GetEndsAtAsync(EmailCooldownType.PasswordReset);
        StartCooldownTimer();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmitAsync()
    {
        errorMessage = null;
        successMessage = null;
        isSubmitting = true;

        var result = await AuthService.ForgotPasswordAsync(new ForgotPasswordRequest
        {
            Email = model.Email.Trim()
        });

        isSubmitting = false;

        if (result.Success)
        {
            cooldownEndsAt = await EmailCooldownService.StartAsync(EmailCooldownType.PasswordReset);
            successMessage = string.IsNullOrWhiteSpace(result.Data?.Message)
                ? "Si la cuenta existe, te hemos enviado un email con instrucciones."
                : result.Data.Message;
            return;
        }

        errorMessage = result.ErrorMessage ?? "No se pudo iniciar la recuperacion de password.";
    }

    private string GetSubmitButtonLabel()
    {
        if (isSubmitting)
        {
            return "Enviando...";
        }

        if (IsCooldownActive)
        {
            return $"Reenviar en {EmailCooldownService.Format(CooldownRemainingSeconds)}";
        }

        return "Enviar instrucciones";
    }

    private void StartCooldownTimer()
    {
        cooldownTimer?.Dispose();
        cooldownTimer = new Timer(_ => _ = HandleCooldownTickAsync(), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task HandleCooldownTickAsync()
    {
        if (disposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(async () =>
            {
                if (disposed || !cooldownEndsAt.HasValue)
                {
                    return;
                }

                if (CooldownRemainingSeconds == 0 && cooldownEndsAt.HasValue)
                {
                    cooldownEndsAt = null;
                    await EmailCooldownService.ClearAsync(EmailCooldownType.PasswordReset);
                }

                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    public void Dispose()
    {
        disposed = true;
        cooldownTimer?.Dispose();
    }

    private sealed class ForgotPasswordModel
    {
        [Required(ErrorMessage = "El email es obligatorio.")]
        [EmailAddress(ErrorMessage = "Email invalido.")]
        public string Email { get; set; } = string.Empty;
    }
}
