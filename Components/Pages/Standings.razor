@page "/standings"
@inject ApiClient ApiClient

<PageTitle>Pick Driver</PageTitle>

<div class="standings-header">
    <div>
        <h1>@GetStandingsTitle()</h1>
        <p class="standings-subtitle text-muted">@Text["Resultados actuales de la temporada."]</p>
    </div>
    <div class="standings-toggle" role="group" aria-label="@Text["Tipo de resultados"]">
        <button type="button" class="standings-toggle__button @(showTeams ? string.Empty : "active")" @onclick="() => SetStandingsMode(false)">@Text["Pilotos"]</button>
        <button type="button" class="standings-toggle__button @(showTeams ? "active" : string.Empty)" @onclick="() => SetStandingsMode(true)">@Text["Equipos"]</button>
    </div>
</div>

<div class="standings-panel">
    @if (isLoading)
    {
        <p class="standings-empty"><em>@Text["Cargando resultados..."]</em></p>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning" role="alert">@errorMessage</div>
    }
    else if (showTeams)
    {
        if (teams.Count == 0)
        {
            <p class="standings-empty">@Text["Sin datos."]</p>
        }
        else
        {
            <table class="standings-table standings-table--teams">
                <thead>
                    <tr>
                        <th class="standings-pos">Pos.</th>
                        <th>@Text["Equipo"]</th>
                        <th class="standings-points">@Text["Pts."]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < teams.Count; i++)
                    {
                        var team = teams[i];
                        <tr>
                            <td class="standings-pos">@(i + 1)</td>
                            <td>
                                <div class="standings-team">
                                    <span class="standings-team__dot" style="background-color: @GetTeamColor(team.Color)"></span>
                                    <span>@team.Name</span>
                                </div>
                            </td>
                            <td class="standings-points">@team.Points</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
    else
    {
        if (drivers.Count == 0)
        {
            <p class="standings-empty">@Text["Sin datos."]</p>
        }
        else
        {
            <table class="standings-table standings-table--drivers">
                <thead>
                    <tr>
                        <th class="standings-pos">Pos.</th>
                        <th>@Text["Piloto"]</th>
                        <th class="standings-country">@Text["Pais"]</th>
                        <th>@Text["Equipo"]</th>
                        <th class="standings-points">@Text["Pts."]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < drivers.Count; i++)
                    {
                        var driver = drivers[i];
                        <tr>
                            <td class="standings-pos">@(i + 1)</td>
                            <td class="standings-driver">@FormatDriverName(driver)</td>
                            <td class="standings-country">@GetDriverCountry(driver)</td>
                            <td>
                                <div class="standings-team">
                                    <span class="standings-team__dot" style="background-color: @GetTeamColor(driver.TeamColor)"></span>
                                    <span>@driver.TeamName</span>
                                </div>
                            </td>
                            <td class="standings-points">@driver.Points</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private readonly List<DriverStanding> drivers = new();
    private readonly List<TeamStanding> teams = new();
    private readonly Dictionary<int, string> driverCountries = new();
    private readonly Dictionary<string, string> driverCountriesByCode = new(StringComparer.OrdinalIgnoreCase);
    private bool showTeams;

    protected override async Task OnInitializedAsync()
    {
        var driversTask = ApiClient.GetAsync<List<DriverStanding>>("standings/f1/drivers");
        var teamsTask = ApiClient.GetAsync<List<TeamStanding>>("standings/f1/teams");
        var driverInfoTask = ApiClient.GetAsync<List<DriverProfile>>("drivers");

        await Task.WhenAll(driversTask, teamsTask, driverInfoTask);

        var driversResult = await driversTask;
        var teamsResult = await teamsTask;
        var driverInfoResult = await driverInfoTask;

        if (driversResult.Success && driversResult.Data is not null)
        {
            drivers.AddRange(driversResult.Data.OrderByDescending(driver => driver.Points));
        }

        if (teamsResult.Success && teamsResult.Data is not null)
        {
            teams.AddRange(teamsResult.Data.OrderByDescending(team => team.Points));
        }

        if (!driversResult.Success || !teamsResult.Success)
        {
            errorMessage = Text.TranslateApiMessage(driversResult.ErrorMessage ?? teamsResult.ErrorMessage, "No se pudieron cargar los resultados.");
        }
        else if (driverInfoResult.Success && driverInfoResult.Data is not null)
        {
            foreach (var info in driverInfoResult.Data)
            {
                var country = NormalizeCountryCode(info.Country);
                if (!string.IsNullOrWhiteSpace(country))
                {
                    driverCountries[info.Id] = country;
                }

                if (!string.IsNullOrWhiteSpace(info.DriverCode) && !string.IsNullOrWhiteSpace(country))
                {
                    driverCountriesByCode[info.DriverCode.Trim()] = country;
                }
            }
        }

        isLoading = false;
    }

    private void SetStandingsMode(bool teamsMode)
    {
        showTeams = teamsMode;
    }

    private string GetStandingsTitle()
    {
        return showTeams ? Text["Resultados de equipos"] : Text["Resultados de pilotos"];
    }

    private static string FormatDriverName(DriverStanding driver)
    {
        return $"{driver.FirstName} {driver.LastName}";
    }

    private string GetDriverCountry(DriverStanding driver)
    {
        if (driverCountries.TryGetValue(driver.DriverId, out var country))
        {
            return country;
        }

        if (!string.IsNullOrWhiteSpace(driver.DriverCode) &&
            driverCountriesByCode.TryGetValue(driver.DriverCode.Trim(), out var countryByCode))
        {
            return countryByCode;
        }

        return "-";
    }

    private static string NormalizeCountryCode(string? country)
    {
        if (string.IsNullOrWhiteSpace(country))
        {
            return string.Empty;
        }

        return country.Trim().ToUpperInvariant();
    }

    private static string GetTeamColor(string? color)
    {
        if (!IsHexColor(color))
        {
            return "#6c757d";
        }

        var trimmed = color!.Trim();
        if (!trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            trimmed = "#" + trimmed;
        }

        return trimmed;
    }

    private static bool IsHexColor(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
        {
            return false;
        }

        var trimmed = color.Trim();
        if (trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            trimmed = trimmed[1..];
        }

        if (trimmed.Length != 3 && trimmed.Length != 6)
        {
            return false;
        }

        foreach (var ch in trimmed)
        {
            var isHex = (ch >= '0' && ch <= '9') ||
                        (ch >= 'a' && ch <= 'f') ||
                        (ch >= 'A' && ch <= 'F');
            if (!isHex)
            {
                return false;
            }
        }

        return true;
    }
}
