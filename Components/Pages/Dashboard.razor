@page "/dashboard"
@using System.Globalization
@using System.Text.Json
@inject ApiClient ApiClient
@inject IAuthSessionStore AuthSessionStore
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Pick Driver</PageTitle>

<div class="dashboard-header">
    <div>
        <h1>@Text["Dashboard"]</h1>
        <p class="dashboard-subtitle text-muted">@Text["Resumen general de tu temporada."]</p>
    </div>
</div>

@if (!isAuthorized)
{
    <p>@Text["Redirigiendo al login..."]</p>
}
else if (isLoading)
{
    <p><em>@Text["Cargando datos..."]</em></p>
}
else
{
    <div class="dashboard-grid">
        <button type="button" class="dashboard-card dashboard-card--interactive" @onclick="NavigateToCalendar" aria-label="@Text["Ir al calendario"]">
            <div class="dashboard-card__header">
                <h2 class="dashboard-card__title">@Text["Proxima carrera"]</h2>
            </div>

            @if (!string.IsNullOrWhiteSpace(nextRaceError))
            {
                <div class="alert alert-warning" role="alert">@nextRaceError</div>
            }
            else if (nextRace is null)
            {
                <p class="dashboard-empty text-muted">@Text["No hay carrera cargada."]</p>
            }
            else
            {
                var flagUrl = GetFlagUrl(nextRace);
                var circuitSimpleUrl = GetCircuitSimpleUrl(nextRace);
                <div class="dashboard-upcoming-race">
                    <div class="race-card race-card--featured">
                        <div class="race-card__top">
                            <span class="race-card__round">@Text.Format("Round {0}", nextRace.Round)</span>
                        </div>
                        <div class="race-card__country">
                            <div class="race-card__flag" style="background-image: url('@flagUrl')"></div>
                            <p class="race-card__title">@GetRaceCountry(nextRace)</p>
                        </div>
                        <p class="race-card__event">@nextRace.Name</p>
                        <div class="race-card__footer">
                            <span class="race-card__date-range">@GetUpcomingRaceDateLabel(nextRace)</span>
                            <div class="race-card__circuit">
                                @if (!string.IsNullOrWhiteSpace(circuitSimpleUrl))
                                {
                                    <img src="@circuitSimpleUrl" alt="@Text.Format("Circuito {0}", nextRace.CircuitName)" />
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </button>

        <section class="dashboard-card @(CanNavigateToLeaguesCard ? "dashboard-card--interactive" : string.Empty)"
                 role="@(CanNavigateToLeaguesCard ? "button" : null)"
                 tabindex="@(CanNavigateToLeaguesCard ? "0" : null)"
                 aria-label="@(CanNavigateToLeaguesCard ? Text["Ir a ligas"] : null)"
                 @onclick="HandleLeagueCardClick"
                 @onkeydown="HandleLeagueCardKeyDown">
            <div class="dashboard-card__header">
                <h2 class="dashboard-card__title">@Text["Tus ligas"]</h2>
            </div>

            @if (!string.IsNullOrWhiteSpace(leaguesError))
            {
                <div class="alert alert-warning" role="alert">@leaguesError</div>
            }
            else if (leagueItems.Count == 0)
            {
                <p class="dashboard-empty text-muted">@Text["Todavia no estas en ninguna liga."]</p>
            }
            else
            {
                if (leaguePositionsPartial)
                {
                    <p class="dashboard-note text-muted">@Text["No se pudo calcular la posicion en todas las ligas."]</p>
                }

                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th>@Text["Liga"]</th>
                            <th>@Text["Status"]</th>
                            <th class="dashboard-points">@Text["Pos."]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in leagueItems)
                        {
                            <tr class="dashboard-row dashboard-row--clickable"
                                role="button"
                                tabindex="0"
                                @onclick="() => HandleLeagueItemClick(item.League)"
                                @onkeydown="args => HandleLeagueRowKeyDown(args, item.League)">
                                <td>@item.League.Name</td>
                                <td><span class="dashboard-status">@Text.Translate(item.League.Status)</span></td>
                                <td class="dashboard-points">@item.PositionLabel</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

        <MobileAppsPanel />

        <button type="button" class="dashboard-card dashboard-card--full dashboard-card--interactive" @onclick="NavigateToResults" aria-label="@Text["Ir a resultados"]">
            <div class="dashboard-card__header">
                <h2 class="dashboard-card__title">@Text["Resultados F1"]</h2>
            </div>

            @if (!string.IsNullOrWhiteSpace(standingsError))
            {
                <div class="alert alert-warning" role="alert">@standingsError</div>
            }
            else
            {
                <div class="dashboard-standings">
                    <div class="dashboard-standings__column">
                        <h3 class="dashboard-standings__title">@Text["Top 5 pilotos"]</h3>
                        @if (topDrivers.Count == 0)
                        {
                            <p class="dashboard-empty text-muted">@Text["Sin datos."]</p>
                        }
                        else
                        {
                            <table class="dashboard-table">
                                <thead>
                                    <tr>
                                        <th class="dashboard-pos">@Text["Pos."]</th>
                                        <th>@Text["Piloto"]</th>
                                        <th>@Text["Equipo"]</th>
                                        <th class="dashboard-points">@Text["Pts."]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < topDrivers.Count; i++)
                                    {
                                        var driver = topDrivers[i];
                                        <tr>
                                            <td class="dashboard-pos">@(i + 1)</td>
                                            <td>@FormatDriverName(driver)</td>
                                            <td>
                                                <div class="dashboard-team">
                                                    <span class="dashboard-team__dot" style="background-color: @GetTeamColor(driver.TeamColor)"></span>
                                                    <span>@driver.TeamName</span>
                                                </div>
                                            </td>
                                            <td class="dashboard-points">@driver.Points</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                    <div class="dashboard-standings__column">
                        <h3 class="dashboard-standings__title">@Text["Top 3 equipos"]</h3>
                        @if (topTeams.Count == 0)
                        {
                            <p class="dashboard-empty text-muted">@Text["Sin datos."]</p>
                        }
                        else
                        {
                            <table class="dashboard-table">
                                <thead>
                                    <tr>
                                        <th class="dashboard-pos">@Text["Pos."]</th>
                                        <th>@Text["Equipo"]</th>
                                        <th class="dashboard-points">@Text["Pts."]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < topTeams.Count; i++)
                                    {
                                        var team = topTeams[i];
                                        <tr>
                                            <td class="dashboard-pos">@(i + 1)</td>
                                            <td>
                                                <div class="dashboard-team">
                                                    <span class="dashboard-team__dot" style="background-color: @GetTeamColor(team.Color)"></span>
                                                    <span>@team.Name</span>
                                                </div>
                                            </td>
                                            <td class="dashboard-points">@team.Points</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
        </button>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isAuthorized;
    private Race? nextRace;
    private string? nextRaceError;
    private string? leaguesError;
    private string? standingsError;
    private bool leaguePositionsPartial;
    private TimeZoneInfo browserTimeZone = TimeZoneInfo.Local;
    private readonly List<LeagueDashboardItem> leagueItems = new();
    private readonly List<DriverStanding> topDrivers = new();
    private readonly List<TeamStanding> topTeams = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthorized = authState.User.Identity?.IsAuthenticated == true;
        if (!isAuthorized)
        {
            RedirectToLogin();
            isLoading = false;
            return;
        }

        var session = await AuthSessionStore.GetAsync();
        var userId = session?.User.Id ?? 0;

        var raceTask = ApiClient.GetAsync<JsonElement>("races/upcoming");
        var leaguesTask = ApiClient.GetAsync<List<LeaguePublic>>("leagues/my", auth: true);
        var driversTask = ApiClient.GetAsync<List<DriverStanding>>("standings/f1/drivers");
        var teamsTask = ApiClient.GetAsync<List<TeamStanding>>("standings/f1/teams");

        await Task.WhenAll(raceTask, leaguesTask, driversTask, teamsTask);

        var raceResult = await raceTask;
        if (raceResult.Success && TryParseRace(raceResult.Data, out var race))
        {
            nextRace = race;
        }
        else
        {
            nextRaceError = Text.TranslateApiMessage(raceResult.ErrorMessage, "No se pudo cargar la proxima carrera.");
        }

        var leaguesResult = await leaguesTask;
        if (leaguesResult.Success && leaguesResult.Data is not null)
        {
            await LoadLeaguePositionsAsync(leaguesResult.Data, userId);
        }
        else if (!leaguesResult.Success)
        {
            leaguesError = Text.TranslateApiMessage(leaguesResult.ErrorMessage, "No se pudieron cargar las ligas.");
        }

        var driversResult = await driversTask;
        var teamsResult = await teamsTask;
        if (driversResult.Success && teamsResult.Success)
        {
            if (driversResult.Data is not null)
            {
                topDrivers.AddRange(driversResult.Data
                    .OrderByDescending(driver => driver.Points)
                    .Take(5));
            }

            if (teamsResult.Data is not null)
            {
                topTeams.AddRange(teamsResult.Data
                    .OrderByDescending(team => team.Points)
                    .Take(3));
            }
        }
        else
        {
            standingsError = Text.TranslateApiMessage(driversResult.ErrorMessage ?? teamsResult.ErrorMessage, "No se pudieron cargar los resultados.");
        }

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ResolveBrowserTimeZoneAsync();
    }

    private async Task LoadLeaguePositionsAsync(List<LeaguePublic> leagues, int userId)
    {
        leagueItems.Clear();
        leaguePositionsPartial = false;

        foreach (var league in leagues)
        {
            var positionLabel = "-";
            var standingsResult = await ApiClient.GetAsync<List<PlayerStanding>>(
                $"players/standings/players?league_id={league.Id}",
                auth: true);

            if (standingsResult.Success && standingsResult.Data is not null)
            {
                var ordered = standingsResult.Data
                    .OrderByDescending(item => item.TotalPoints)
                    .ThenBy(item => item.Username, StringComparer.OrdinalIgnoreCase)
                    .ToList();

                var index = ordered.FindIndex(item => item.UserId == userId);
                if (index >= 0)
                {
                    positionLabel = $"{index + 1} / {ordered.Count}";
                }
                else
                {
                    positionLabel = $"- / {ordered.Count}";
                }
            }
            else
            {
                leaguePositionsPartial = true;
            }

            leagueItems.Add(new LeagueDashboardItem(league, positionLabel));
        }
    }

    private void RedirectToLogin()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/" : "/" + relative;
        var encoded = Uri.EscapeDataString(target);
        NavigationManager.NavigateTo($"/login?returnUrl={encoded}");
    }

    private bool CanNavigateToLeaguesCard => leagueItems.Count == 0 && string.IsNullOrWhiteSpace(leaguesError);

    private void NavigateToCalendar()
    {
        NavigationManager.NavigateTo("/races");
    }

    private void NavigateToResults()
    {
        NavigationManager.NavigateTo("/standings");
    }

    private void HandleLeagueCardClick()
    {
        if (CanNavigateToLeaguesCard)
        {
            NavigationManager.NavigateTo("/leagues");
        }
    }

    private void HandleLeagueCardKeyDown(KeyboardEventArgs args)
    {
        if (CanNavigateToLeaguesCard && IsActivationKey(args))
        {
            NavigationManager.NavigateTo("/leagues");
        }
    }

    private void HandleLeagueRowKeyDown(KeyboardEventArgs args, LeaguePublic league)
    {
        if (IsActivationKey(args))
        {
            HandleLeagueItemClick(league);
        }
    }

    private void HandleLeagueItemClick(LeaguePublic league)
    {
        if (IsActive(league.Status))
        {
            NavigationManager.NavigateTo($"/leagues/{league.Id}/draft");
            return;
        }

        NavigationManager.NavigateTo($"/leagues/{league.Id}");
    }

    private static bool IsActive(string? status)
    {
        return string.Equals(status, "active", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsActivationKey(KeyboardEventArgs args)
    {
        return args.Key == "Enter" || args.Key == " ";
    }

    private static bool TryParseRace(JsonElement payload, out Race? race)
    {
        race = null;

        if (payload.ValueKind == JsonValueKind.Object)
        {
            race = payload.Deserialize<Race>(ApiJson.Options);
            return race is not null;
        }

        if (payload.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in payload.EnumerateArray())
            {
                if (item.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                race = item.Deserialize<Race>(ApiJson.Options);
                if (race is not null)
                {
                    return true;
                }
            }
        }

        return false;
    }

    private string FormatRaceDate(DateTimeOffset? date)
    {
        if (!date.HasValue)
        {
            return Text["Por confirmar"];
        }

        var browserLocal = TimeZoneInfo.ConvertTime(date.Value, browserTimeZone);
        return browserLocal.ToString("dd MMM yyyy HH:mm", CultureInfo.CurrentCulture);
    }

    private static string GetRaceCountry(Race race)
    {
        return string.IsNullOrWhiteSpace(race.Country) ? race.Name : race.Country;
    }

    private string GetUpcomingRaceDateLabel(Race race)
    {
        if (!race.Fp1Time.HasValue || !race.RaceTime.HasValue)
        {
            return FormatRaceDate(race.RaceTime);
        }

        var fp1Date = ToBrowserLocalTime(race.Fp1Time.Value);
        var raceDate = ToBrowserLocalTime(race.RaceTime.Value);
        return $"{fp1Date:dd} - {raceDate:dd} {GetMonthCode(raceDate.Month)}";
    }

    private static string GetFlagUrl(Race race)
    {
        return race.Media?.CountryFlagURL ?? string.Empty;
    }

    private static string GetCircuitSimpleUrl(Race race)
    {
        return race.Media?.CircuitSimpleURL ?? string.Empty;
    }

    private static string GetMonthCode(int month)
    {
        var monthNames = CultureInfo.CurrentCulture.DateTimeFormat.AbbreviatedMonthNames;
        return month >= 1 && month <= 12
            ? monthNames[month - 1].ToUpperInvariant()
            : "N/A";
    }

    private DateTimeOffset ToBrowserLocalTime(DateTimeOffset value)
    {
        return TimeZoneInfo.ConvertTime(value, browserTimeZone);
    }

    private async Task ResolveBrowserTimeZoneAsync()
    {
        try
        {
            var timeZoneId = await JSRuntime.InvokeAsync<string?>("pickdriverRaces.getBrowserTimeZone");
            if (string.IsNullOrWhiteSpace(timeZoneId))
            {
                return;
            }

            var resolved = ResolveTimeZone(timeZoneId);
            if (!string.Equals(browserTimeZone.Id, resolved.Id, StringComparison.Ordinal))
            {
                browserTimeZone = resolved;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Fall back to server-local time zone if browser zone is unavailable.
        }
    }

    private static TimeZoneInfo ResolveTimeZone(string timeZoneId)
    {
        try
        {
            return TimeZoneInfo.FindSystemTimeZoneById(timeZoneId);
        }
        catch
        {
            return TimeZoneInfo.Utc;
        }
    }

    private static string FormatDriverName(DriverStanding driver)
    {
        return $"{driver.FirstName} {driver.LastName}";
    }

    private static string GetTeamColor(string? color)
    {
        if (!IsHexColor(color))
        {
            return "#6c757d";
        }

        var trimmed = color!.Trim();
        if (!trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            trimmed = "#" + trimmed;
        }

        return trimmed;
    }

    private static bool IsHexColor(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
        {
            return false;
        }

        var trimmed = color.Trim();
        if (trimmed.StartsWith("#", StringComparison.Ordinal))
        {
            trimmed = trimmed[1..];
        }

        if (trimmed.Length != 3 && trimmed.Length != 6)
        {
            return false;
        }

        foreach (var ch in trimmed)
        {
            var isHex = (ch >= '0' && ch <= '9') ||
                        (ch >= 'a' && ch <= 'f') ||
                        (ch >= 'A' && ch <= 'F');
            if (!isHex)
            {
                return false;
            }
        }

        return true;
    }

    private sealed record LeagueDashboardItem(LeaguePublic League, string PositionLabel);
}
