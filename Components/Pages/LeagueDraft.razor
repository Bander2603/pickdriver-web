    private IReadOnlyList<BanUsageEntry> BansUsageEntries
        => BuildBansUsageEntries();

    private string BansHeaderLabel
        => league?.TeamsEnabled == true ? "Equipo" : "Jugador";

    private int? LastPickUserId
        => raceDraft is not null && raceDraft.CurrentPickIndex > 0
            ? raceDraft.PickOrder[raceDraft.CurrentPickIndex - 1]
            : null;

    private int? LastPickDriverId
        => GetLastPickDriverId();

    private bool IsYourTurn
        => CurrentPickUserId.HasValue && CurrentPickUserId.Value == userId;

    private int? EditableOwnPickIndex
        => raceDraft is not null
            && raceDraft.CurrentPickIndex > 0
            && raceDraft.CurrentPickIndex - 1 < raceDraft.PickOrder.Count
            && raceDraft.CurrentPickIndex - 1 < raceDraft.PickedDriverIds.Count
            && raceDraft.PickOrder[raceDraft.CurrentPickIndex - 1] == userId
            && raceDraft.PickedDriverIds[raceDraft.CurrentPickIndex - 1].HasValue
            ? raceDraft.CurrentPickIndex - 1
            : null;

    private bool CanEditPreviousPick
        => EditableOwnPickIndex.HasValue;

    private bool IsPickActionActive
        => IsYourTurn || CanEditPreviousPick;

    private bool IsEditingPreviousPick
        => !IsYourTurn && CanEditPreviousPick;

    private string PickActionButtonLabel
        => IsEditingPreviousPick ? "Cambiar Pick" : "Pick";

    private string PickModalTitle
        => IsEditingPreviousPick ? "Cambiar Pick" : "Elegir piloto";

    private string PickConfirmButtonLabel
        => isSubmittingPick
            ? (IsEditingPreviousPick ? "Cambiando..." : "Confirmando...")
            : (IsEditingPreviousPick ? "Cambiar pick" : "Confirmar pick");

    private int BansLimit
        => league?.TeamsEnabled == true ? 3 : 2;

    private int BansLimitPerRace
        => 1;

    private bool HasRemainingBans
        => GetBansUsedForCurrentSide() < BansLimit;

    private bool HasRemainingBansThisRace
        => GetBansUsedForCurrentSide() < BansLimitPerRace;

    private bool IsBanTargetSameTeam
        => league?.TeamsEnabled == true
            && LastPickUserId.HasValue
            && IsSameTeam(userId, LastPickUserId.Value);

    private bool IsBanTargetAlreadyBannedInRace
        => league?.TeamsEnabled != true
            && lastPickInfo is not null
            && IsUserAlreadyBannedInRace(lastPickInfo.UserId);

    private bool CanBanByTurn
    {
        get
        {
            if (CurrentPickUserId is null)
            {
                return false;
            }

            if (league?.TeamsEnabled == true)
            {
                return CurrentPickUserId.Value == userId || IsSameTeam(userId, CurrentPickUserId.Value);
            }

            return CurrentPickUserId.Value == userId;
        }
    }

