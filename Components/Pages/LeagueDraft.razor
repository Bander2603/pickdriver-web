    private bool IsPickDisabled
        => !IsPickActionActive || availablePickDrivers.Count == 0 || isSubmittingPick || raceDraft is null || draftRace is null;

    private bool IsConfirmPickDisabled
        => isSubmittingPick || selectedPickDriverId is null || availablePickDrivers.Count == 0;

    private bool IsBanDisabled
        => isSubmittingBan
            || raceDraft is null
            || raceDraft.CurrentPickIndex == 0
            || lastPickInfo is null
            || !HasRemainingBans
            || !HasRemainingBansThisRace
            || IsBanTargetSameTeam
            || IsBanTargetAlreadyBannedInRace
            || !CanBanByTurn;

    private bool IsConfirmBanDisabled
        => isSubmittingBan || lastPickInfo is null;

    private IReadOnlyList<Driver> GetAvailableDriversForPick()
    {
        if (drivers.Count == 0)
        {
            return Array.Empty<Driver>();
        }

        var pickedSet = new HashSet<int>(GetPickedDriverIds());
        var bannedSet = new HashSet<int>(GetBannedDriverIds());
        var editablePickedDriverId = GetEditablePickedDriverId();

        return drivers
            .Where(driver =>
            {
                var isCurrentEditablePick = editablePickedDriverId.HasValue && editablePickedDriverId.Value == driver.Id;
                var isUnavailableByPick = pickedSet.Contains(driver.Id) && !isCurrentEditablePick;
                return !isUnavailableByPick && !bannedSet.Contains(driver.Id);
            })
            .OrderBy(driver => driver.LastName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(driver => driver.FirstName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private IReadOnlyList<Driver> GetAutopickAvailableDrivers()
    {
        if (drivers.Count == 0)
        {
            return Array.Empty<Driver>();
        }

        var selected = autopickDriverIds.Count > 0 ? new HashSet<int>(autopickDriverIds) : new HashSet<int>();
        return drivers
            .Where(driver => !selected.Contains(driver.Id))
            .OrderBy(driver => driver.LastName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(driver => driver.FirstName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private string GetDriverLabel(Driver driver)
    {
        return $"{driver.FirstName} {driver.LastName} · {driver.DriverCode}";
    }

    private string GetDriverName(int driverId)
    {
        var driver = drivers.FirstOrDefault(item => item.Id == driverId);
        return driver is null ? $"#{driverId}" : $"{driver.FirstName} {driver.LastName}";
    }

    private string BuildOptionsLabel()
    {
        if (league is null)
        {
            return "Sin opciones especiales";
        }

        var options = new List<string>();
        if (league.TeamsEnabled)
        {
            options.Add("Teams");
        }

        if (league.BansEnabled)
        {
            options.Add("Bans");
        }

        if (league.MirrorPicksEnabled)
        {
            options.Add("Mirror");
        }

        return options.Count == 0 ? "Sin opciones especiales" : string.Join(" · ", options);
    }

    private string BuildDraftProgressLabel()
    {
        if (draftRace is null || allRaces.Count == 0)
        {
            return "-";
        }

        var initialRound = league?.InitialRaceRound ?? 1;
        var totalDrafts = allRaces.Count(race => race.Round >= initialRound);
        var currentDraft = allRaces.Count(race => race.Round >= initialRound && race.Round <= draftRace.Round);

        if (totalDrafts == 0)
        {
            return "-";
        }

        return $"Draft {currentDraft}/{totalDrafts}";
    }

    private IReadOnlyList<PickBadge> GetPickBadges(int index, bool isCurrent)
    {
        var pickDriverId = raceDraft?.PickedDriverIds.Count > index ? raceDraft.PickedDriverIds[index] : null;
        var bannedDriverId = GetBannedDriverForIndex(index);
        var badges = new List<PickBadge>(2);

        if (bannedDriverId.HasValue)
        {
            badges.Add(new PickBadge(GetDriverName(bannedDriverId.Value), "draft-order__badge draft-order__badge--banned"));
        }

        if (pickDriverId.HasValue)
        {
            badges.Add(new PickBadge(GetDriverName(pickDriverId.Value), "draft-order__badge"));
        }
        else if (isCurrent)
        {
            badges.Add(new PickBadge("Turno actual", "draft-order__badge"));
        }
        else if (!bannedDriverId.HasValue && raceDraft is not null && index < raceDraft.CurrentPickIndex)
        {
            badges.Add(new PickBadge("Missed pick", "draft-order__badge draft-order__badge--missed"));
        }

        return badges;
    }

    private int? GetBannedDriverForIndex(int index)
    {
        if (raceDraft?.BannedDriverIdsByPickIndex.Count > index)
        {
            return raceDraft.BannedDriverIdsByPickIndex[index];
        }

        return null;
    }

    private IReadOnlyList<int> GetPickedDriverIds()
    {
        if (raceDraft?.PickedDriverIds.Count > 0)
        {
            return raceDraft.PickedDriverIds
                .Where(id => id.HasValue)
                .Select(id => id!.Value)
                .ToList();
        }

        return draftState?.PickedDriverIds ?? new List<int>();
    }

    private IReadOnlyList<int> GetBannedDriverIds()
    {
        if (raceDraft?.BannedDriverIds.Count > 0)
        {
            return raceDraft.BannedDriverIds;
        }

        return draftState?.BannedDriverIds ?? new List<int>();
    }

    private int? GetLastPickDriverId()
    {
        if (raceDraft is not null && raceDraft.CurrentPickIndex > 0 && raceDraft.PickedDriverIds.Count > raceDraft.CurrentPickIndex - 1)
        {
            return raceDraft.PickedDriverIds[raceDraft.CurrentPickIndex - 1];
        }

        if (draftState?.PickedDriverIds.Count > 0)
        {
            return draftState.PickedDriverIds[^1];
        }

        return null;
    }

    private int? GetEditablePickedDriverId()
    {
        if (raceDraft is null || !EditableOwnPickIndex.HasValue)
        {
            return null;
        }

        var index = EditableOwnPickIndex.Value;
        if (index < 0 || index >= raceDraft.PickedDriverIds.Count)
        {
            return null;
        }

        return raceDraft.PickedDriverIds[index];
    }

    private int GetBansUsedForCurrentSide()
    {
        if (league?.BansEnabled != true)
        {
            return 0;
        }

        if (league.TeamsEnabled)
        {
            var teamId = GetUserTeamId(userId);
            return teamId.HasValue ? GetBansUsedForTeam(teamId.Value) : 0;
        }

        return GetBansUsedForUser(userId);
    }

    private IReadOnlyList<BanUsageEntry> BuildBansUsageEntries()
    {
        if (league?.BansEnabled != true)
        {
            return Array.Empty<BanUsageEntry>();
        }

        var raceLimit = BansLimitPerRace;
        var seasonLimit = BansLimit;
        var usedByUserInRace = BuildBansUsedByUser(raceDraft);
        var usedByUserSeason = seasonBansUsedByUser;
        var entries = new List<BanUsageEntry>();

        if (league.TeamsEnabled && teams.Count > 0)
        {
            foreach (var team in teams)
            {
                var raceUsed = usedByUserInRace.Count == 0 && bansUsedByTeam.TryGetValue(team.Id, out var localUsed)
                    ? localUsed
                    : team.Members.Sum(member => usedByUserInRace.TryGetValue(member.User.Id, out var count) ? count : 0);
                var seasonUsed = team.Members.Sum(member => usedByUserSeason.TryGetValue(member.User.Id, out var count) ? count : 0);
                entries.Add(new BanUsageEntry(team.Name, raceUsed, raceLimit, seasonUsed, seasonLimit));
            }

            return entries;
        }

        foreach (var member in members)
        {
            var raceUsed = usedByUserInRace.Count == 0 && bansUsedByTeam.TryGetValue(member.Id, out var localUsed)
                ? localUsed
                : (usedByUserInRace.TryGetValue(member.Id, out var count) ? count : 0);
            var seasonUsed = usedByUserSeason.TryGetValue(member.Id, out var seasonCount) ? seasonCount : 0;
            entries.Add(new BanUsageEntry(member.Username, raceUsed, raceLimit, seasonUsed, seasonLimit));
        }

        return entries;
    }

    private static Dictionary<int, int> BuildBansUsedByUser(RaceDraft? draft)
    {
        var counts = new Dictionary<int, int>();
        if (draft is null || draft.PickOrder.Count == 0)
        {
            return counts;
        }

        var pickOrderCount = draft.PickOrder.Count;
        var limit = Math.Min(pickOrderCount, draft.BannedDriverIdsByPickIndex.Count);
        for (var i = 0; i < limit; i++)
        {
            if (!draft.BannedDriverIdsByPickIndex[i].HasValue)
            {
                continue;
            }

            var bannerIndex = i + 1;
            if (bannerIndex >= pickOrderCount)
            {
                bannerIndex = 0;
            }
            var banningUserId = draft.PickOrder[bannerIndex];
            counts[banningUserId] = counts.TryGetValue(banningUserId, out var current) ? current + 1 : 1;
        }

        return counts;
    }

    private bool IsUserAlreadyBannedInRace(int targetUserId)
    {
        if (raceDraft is null || raceDraft.PickOrder.Count == 0 || raceDraft.BannedDriverIdsByPickIndex.Count == 0)
        {
            return false;
        }

        var limit = Math.Min(raceDraft.PickOrder.Count, raceDraft.BannedDriverIdsByPickIndex.Count);
        for (var i = 0; i < limit; i++)
        {
            if (!raceDraft.BannedDriverIdsByPickIndex[i].HasValue)
            {
                continue;
            }

            if (raceDraft.PickOrder[i] == targetUserId)
            {
                return true;
            }
        }

        return false;
    }

    private int GetBansUsedForUser(int targetUserId)
    {
        var counts = BuildBansUsedByUser(raceDraft);
        if (counts.Count > 0)
        {
            return counts.TryGetValue(targetUserId, out var count) ? count : 0;
        }

        return bansUsedByTeam.TryGetValue(targetUserId, out var localCount) ? localCount : 0;
    }

    private int GetBansUsedForTeam(int teamId)
    {
        var counts = BuildBansUsedByUser(raceDraft);
        if (counts.Count > 0)
        {
            var team = teams.FirstOrDefault(item => item.Id == teamId);
            if (team is null)
            {
                return 0;
            }

            return team.Members.Sum(member => counts.TryGetValue(member.User.Id, out var count) ? count : 0);
        }

        return bansUsedByTeam.TryGetValue(teamId, out var localCount) ? localCount : 0;
    }

    private void UpdateLastPickInfo()
    {
        lastPickInfo = null;

        if (LastPickUserId is null || LastPickDriverId is null)
        {
            return;
        }

        lastPickInfo = new PickInfo
        {
            UserId = LastPickUserId.Value,
            Username = GetMemberName(LastPickUserId.Value),
            DriverId = LastPickDriverId.Value,
            DriverName = GetDriverName(LastPickDriverId.Value)
        };
    }

    private int? GetUserTeamId(int userId)
    {
        foreach (var team in teams)
        {
            if (team.Members.Any(member => member.User.Id == userId))
            {
                return team.Id;
            }
        }

        return null;
    }

    private bool IsSameTeam(int userA, int userB)
    {
        var teamA = GetUserTeamId(userA);
        var teamB = GetUserTeamId(userB);
        return teamA.HasValue && teamB.HasValue && teamA.Value == teamB.Value;
    }

    private string GetMemberName(int userId)
    {
        var member = members.FirstOrDefault(item => item.Id == userId);
        return member?.Username ?? $"#{userId}";
    }

    private string FormatDate(DateTimeOffset? date)
    {
        return date?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-";
    }

    private async Task HandleHistoryRaceChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var round))
        {
            selectedHistoryRound = round;
            await LoadRaceHistoryAsync(round);
        }
    }

    private async Task LoadUserHistoryAsync(int userId)
    {
        historyErrorMessage = null;
        pickHistory.Clear();

        var history = await GetHistoryForUserAsync(userId);
        if (history is not null)
        {
            pickHistory.AddRange(history.OrderBy(entry => entry.Round));
            return;
        }

        historyErrorMessage ??= "No se pudo cargar el historial.";
    }

    private async Task<List<PickHistory>?> GetHistoryForUserAsync(int userId)
    {
        if (historyCache.TryGetValue(userId, out var cached))
        {
            return cached;
        }

        var result = await ApiClient.GetAsync<List<PickHistory>>($"players/standings/picks?league_id={LeagueId}&user_id={userId}", auth: true);
        if (result.Success && result.Data is not null)
        {
            historyCache[userId] = result.Data;
            return result.Data;
        }

        historyErrorMessage ??= result.ErrorMessage;
        historyCache[userId] = emptyHistory;
        return null;
    }

    private async Task LoadRaceHistoryAsync(int round)
    {
        historyErrorMessage = null;
        racePickRows.Clear();

        await EnsureAllHistoryLoadedAsync();

        foreach (var member in members)
        {
            if (!historyCache.TryGetValue(member.Id, out var history))
            {
                continue;
            }

            foreach (var entry in history.Where(item => item.Round == round))
            {
                racePickRows.Add(new RacePickRow
                {
                    Username = member.Username,
                    PickPosition = entry.PickPosition,
                    DriverName = entry.DriverName,
                    Points = entry.Points
                });
            }
        }

        racePickRows.Sort((a, b) =>
        {
            var pickComparison = a.PickPosition.CompareTo(b.PickPosition);
            return pickComparison != 0 ? pickComparison : string.Compare(a.Username, b.Username, StringComparison.OrdinalIgnoreCase);
        });
    }

    private async Task EnsureAllHistoryLoadedAsync()
    {
        var failed = false;

        foreach (var member in members)
        {
            if (historyCache.ContainsKey(member.Id))
            {
                continue;
            }

            var history = await GetHistoryForUserAsync(member.Id);
            if (history is null)
            {
                failed = true;
            }
        }

        if (failed)
        {
            historyErrorMessage ??= "No se pudo cargar el historial de todos los jugadores.";
        }
    }

    private async Task OpenPickModal()
    {
        if (IsPickDisabled)
        {
            return;
        }

        draftActionMessage = null;
        selectedPickDriverId = null;
        if (draftRace is not null)
        {
            await LoadDraftAsync(draftRace.Id);
        }

        var editableDriverId = GetEditablePickedDriverId();
        if (editableDriverId.HasValue && availablePickDrivers.Any(driver => driver.Id == editableDriverId.Value))
        {
            selectedPickDriverId = editableDriverId.Value;
        }

        showPickModal = true;
    }

    private void ClosePickModal()
    {
        if (isSubmittingPick)
        {
            return;
        }

        showPickModal = false;
        selectedPickDriverId = null;
    }

    private void HandlePickDriverChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var driverId))
        {
            selectedPickDriverId = driverId;
        }
        else
        {
            selectedPickDriverId = null;
        }
    }

    private async Task ConfirmPickAsync()
    {
        if (draftRace is null || selectedPickDriverId is null)
        {
            return;
        }

        isSubmittingPick = true;
        draftActionMessage = null;

        var request = BuildPickPayload(selectedPickDriverId.Value);
        var result = await ApiClient.PostAsync<Dictionary<string, int>, DraftResponse>($"leagues/{LeagueId}/draft/{draftRace.Id}/pick", request, auth: true);

        isSubmittingPick = false;

        if (result.Success && result.Data is not null)
        {
            ApplyDraftResponse(result.Data, pickedDriverId: selectedPickDriverId.Value);
            showPickModal = false;
            selectedPickDriverId = null;
            if (draftRace is not null)
            {
                await LoadDraftAsync(draftRace.Id);
            }
            return;
        }

        draftActionMessage = MapPickErrorMessage(result.ErrorMessage);
    }

    private async Task OpenBanModal()
    {
        if (IsBanDisabled)
        {
            return;
        }

        draftActionMessage = null;
        if (draftRace is not null)
        {
            await LoadDraftAsync(draftRace.Id);
        }
        showBanModal = true;
    }

    private void CloseBanModal()
    {
        if (isSubmittingBan)
        {
            return;
        }

        showBanModal = false;
    }

    private async Task ConfirmBanAsync()
    {
        if (draftRace is null || lastPickInfo is null)
        {
            return;
        }

        isSubmittingBan = true;
        draftActionMessage = null;

        var request = BuildBanPayload(lastPickInfo.UserId, lastPickInfo.DriverId);
        var result = await ApiClient.PostAsync<Dictionary<string, int>, DraftResponse>($"leagues/{LeagueId}/draft/{draftRace.Id}/ban", request, auth: true);

        isSubmittingBan = false;

        if (result.Success && result.Data is not null)
        {
            TrackBanUsage();
            ApplyDraftResponse(result.Data, bannedDriverId: lastPickInfo.DriverId);
            showBanModal = false;
            if (draftRace is not null)
            {
                await LoadDraftAsync(draftRace.Id);
            }
            return;
        }

        draftActionMessage = result.ErrorMessage ?? "No se pudo completar el ban.";
    }

    private async Task OpenAutopickModal()
    {
        autopickMessage = null;
        showAutopickModal = true;
        if (!autopickLoaded)
        {
            await LoadAutopickAsync();
        }
    }

    private void CloseAutopickModal()
    {
        if (isSubmittingAutopick)
        {
            return;
        }

        showAutopickModal = false;
    }

    private async Task LoadAutopickAsync()
    {
        if (league is null)
        {
            return;
        }

        isLoadingAutopick = true;
        autopickMessage = null;
        autopickDriverIds.Clear();

        var result = await ApiClient.GetAsync<AutopickSettings>($"leagues/{LeagueId}/autopick", auth: true);
        if (result.Success && result.Data is not null)
        {
            autopickDriverIds.AddRange(result.Data.DriverIds.Distinct());
            hasAutopickSaved = autopickDriverIds.Count > 0;
        }
        else if (!result.Success)
        {
            autopickMessage = result.ErrorMessage ?? "No se pudo cargar el autopick.";
        }

        autopickAddDriverId = autopickAvailableDrivers.FirstOrDefault()?.Id;
        isLoadingAutopick = false;
        autopickLoaded = true;
    }

    private async Task LoadAutopickSummaryAsync()
    {
        if (autopickLoaded || league is null)
        {
            return;
        }

        var result = await ApiClient.GetAsync<AutopickSettings>($"leagues/{LeagueId}/autopick", auth: true);
        if (result.Success && result.Data is not null)
        {
            autopickDriverIds.Clear();
            autopickDriverIds.AddRange(result.Data.DriverIds.Distinct());
            hasAutopickSaved = autopickDriverIds.Count > 0;
            autopickLoaded = true;
        }
    }

    private void HandleAutopickAddChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var driverId))
        {
            autopickAddDriverId = driverId;
        }
        else
        {
            autopickAddDriverId = null;
        }
    }

    private void AddAutopickDriver()
    {
        if (!autopickAddDriverId.HasValue)
        {
            return;
        }

        var driverId = autopickAddDriverId.Value;
        if (!autopickDriverIds.Contains(driverId))
        {
            autopickDriverIds.Add(driverId);
        }

        autopickAddDriverId = autopickAvailableDrivers.FirstOrDefault()?.Id;
    }

    private void MoveAutopickDriver(int index, int direction)
    {
        var targetIndex = index + direction;
        if (index < 0 || index >= autopickDriverIds.Count || targetIndex < 0 || targetIndex >= autopickDriverIds.Count)
        {
            return;
        }

        (autopickDriverIds[index], autopickDriverIds[targetIndex]) = (autopickDriverIds[targetIndex], autopickDriverIds[index]);
    }

    private void RemoveAutopickDriver(int index)
    {
        if (index < 0 || index >= autopickDriverIds.Count)
        {
            return;
        }

        autopickDriverIds.RemoveAt(index);
        autopickAddDriverId ??= autopickAvailableDrivers.FirstOrDefault()?.Id;
    }

    private async Task SaveAutopickAsync()
    {
        isSubmittingAutopick = true;
        autopickMessage = null;

        var request = new AutopickSettings
        {
            DriverIds = autopickDriverIds.Distinct().ToList()
        };

        var result = await ApiClient.PutAsync<AutopickSettings, AutopickSettings>($"leagues/{LeagueId}/autopick", request, auth: true);

        isSubmittingAutopick = false;

        if (result.Success)
        {
            hasAutopickSaved = autopickDriverIds.Count > 0;
            showAutopickModal = false;
            return;
        }

        autopickMessage = result.ErrorMessage ?? "No se pudo guardar el autopick.";
    }

    private void ApplyDraftResponse(DraftResponse response, int? pickedDriverId = null, int? bannedDriverId = null)
    {
        draftState = response;
        if (raceDraft is not null)
        {
            raceDraft.CurrentPickIndex = response.CurrentPickIndex;
            raceDraft.Status = response.Status;

            if (pickedDriverId.HasValue && raceDraft.PickedDriverIds.Count == raceDraft.PickOrder.Count)
            {
                var pickIndex = Math.Max(0, response.CurrentPickIndex - 1);
                if (pickIndex < raceDraft.PickedDriverIds.Count)
                {
                    raceDraft.PickedDriverIds[pickIndex] = pickedDriverId.Value;
                }
            }

            if (bannedDriverId.HasValue && raceDraft.PickedDriverIds.Count == raceDraft.PickOrder.Count)
            {
                var banIndex = response.CurrentPickIndex;
                if (banIndex >= 0 && banIndex < raceDraft.PickedDriverIds.Count)
                {
                    raceDraft.PickedDriverIds[banIndex] = null;
                }

                if (!raceDraft.BannedDriverIds.Contains(bannedDriverId.Value))
                {
                    raceDraft.BannedDriverIds.Add(bannedDriverId.Value);
                }

                if (raceDraft.BannedDriverIdsByPickIndex.Count == raceDraft.PickOrder.Count)
                {
                    raceDraft.BannedDriverIdsByPickIndex[banIndex] = bannedDriverId.Value;
                }
            }
        }

        UpdateLastPickInfo();
    }

    private void TrackBanUsage()
    {
        if (league?.BansEnabled != true)
        {
            return;
        }

        if (league.TeamsEnabled)
        {
            var teamId = GetUserTeamId(userId);
            if (teamId.HasValue)
            {
                bansUsedByTeam[teamId.Value] = bansUsedByTeam.TryGetValue(teamId.Value, out var count) ? count + 1 : 1;
            }
        }
        else
        {
            bansUsedByTeam[userId] = bansUsedByTeam.TryGetValue(userId, out var count) ? count + 1 : 1;
        }

        if (seasonBansLoaded)
        {
            seasonBansUsedByUser[userId] = seasonBansUsedByUser.TryGetValue(userId, out var count) ? count + 1 : 1;
        }
    }

    private static Dictionary<string, int> BuildPickPayload(int driverId)
    {
        return new Dictionary<string, int>
        {
            ["driverID"] = driverId,
            ["driverId"] = driverId,
            ["driver_id"] = driverId
        };
    }

    private static string MapPickErrorMessage(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
        {
            return "No se pudo realizar el pick.";
        }

        var normalized = NormalizeReasonForMatch(rawMessage);
        return normalized switch
        {
            "your turn is no longer active" => "Tu turno ya no esta activo para cambiar el pick.",
            "driver no longer available" => "Ese piloto ya no esta disponible.",
            "it's not your turn to pick" => "Ya no es tu turno para pickear.",
            "its not your turn to pick" => "Ya no es tu turno para pickear.",
            _ => rawMessage
        };
    }

    private static string NormalizeReasonForMatch(string reason)
    {
        var normalized = reason.Trim().ToLowerInvariant().Replace('’', '\'');
        while (normalized.Contains("  ", StringComparison.Ordinal))
        {
            normalized = normalized.Replace("  ", " ", StringComparison.Ordinal);
        }

        return normalized;
    }

    private static Dictionary<string, int> BuildBanPayload(int targetUserId, int driverId)
    {
        return new Dictionary<string, int>
        {
            ["targetUserID"] = targetUserId,
            ["targetUserId"] = targetUserId,
            ["target_user_id"] = targetUserId,
            ["driverID"] = driverId,
            ["driverId"] = driverId,
            ["driver_id"] = driverId
        };
    }

    private void SetTab(LeagueTab tab)
    {
        activeTab = tab;
        EnsureDraftPollingStarted();
    }

    private void EnsureDraftPollingStarted()
    {
        if (!isAuthorized || draftPollingTask is not null)
        {
            return;
        }

        draftPollingCts = new CancellationTokenSource();
        draftPollingTask = RunDraftPollingAsync(draftPollingCts.Token);
    }

    private async Task RunDraftPollingAsync(CancellationToken token)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(DraftPollingIntervalSeconds));
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                if (token.IsCancellationRequested || disposed)
                {
                    return;
                }

                if (activeTab != LeagueTab.Draft || draftRace is null)
                {
                    continue;
                }

                if (isDraftRefreshing || isSubmittingPick || isSubmittingBan)
                {
                    continue;
                }

                await InvokeAsync(RefreshDraftAsync);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task RefreshDraftAsync()
    {
        if (draftRace is null || isDraftRefreshing)
        {
            return;
        }

        isDraftRefreshing = true;
        try
        {
            await LoadDraftAsync(draftRace.Id);
        }
        finally
        {
            isDraftRefreshing = false;
            if (!disposed)
            {
                try
                {
                    await InvokeAsync(StateHasChanged);
                }
                catch (ObjectDisposedException)
                {
                }
                catch (InvalidOperationException)
                {
                }
            }
        }
    }

    private async Task LoadSeasonBansUsageSafelyAsync()
    {
        try
        {
            await LoadSeasonBansUsageAsync();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task LoadSeasonBansUsageAsync()
    {
        if (league?.BansEnabled != true || isLoadingSeasonBans || seasonBansLoaded || allRaces.Count == 0 || draftRace is null)
        {
            return;
        }

        isLoadingSeasonBans = true;
        seasonBansUsedByUser.Clear();
        try
        {
            var initialRound = league?.InitialRaceRound ?? 1;
            var maxRound = draftRace.Round;
            var targetRaces = allRaces
                .Where(race => race.Round >= initialRound && race.Round <= maxRound)
                .ToList();

            if (targetRaces.Count == 0)
            {
                seasonBansLoaded = true;
                return;
            }

            var tasks = targetRaces
                .Select(race => ApiClient.GetAsync<RaceDraft>($"leagues/{LeagueId}/draft/{race.Id}", auth: true))
                .ToList();

            var results = await Task.WhenAll(tasks);
            foreach (var result in results)
            {
                if (!result.Success || result.Data is null)
                {
                    continue;
                }

                var counts = BuildBansUsedByUser(result.Data);
                foreach (var entry in counts)
                {
                    seasonBansUsedByUser[entry.Key] = seasonBansUsedByUser.TryGetValue(entry.Key, out var current)
                        ? current + entry.Value
                        : entry.Value;
                }
            }

            seasonBansLoaded = true;
            if (!disposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            isLoadingSeasonBans = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        if (draftPollingCts is null)
        {
            return;
        }

        draftPollingCts.Cancel();
        if (draftPollingTask is not null)
        {
            try
            {
                await draftPollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        draftPollingCts.Dispose();
        draftPollingCts = null;
        draftPollingTask = null;
    }

    private void SetStandingsMode(bool showTeams)
    {
        showTeamStandings = showTeams;
    }

    private List<PlayerStanding> GetSortedPlayerStandings()
    {
        var query = standingsSortFilter switch
        {
            StandingsSortFilter.Deviation => playerStandings
                .OrderByDescending(item => item.TotalDeviation)
                .ThenByDescending(item => item.TotalPoints)
                .ThenBy(item => item.Username, StringComparer.OrdinalIgnoreCase),
            _ => playerStandings
                .OrderByDescending(item => item.TotalPoints)
                .ThenByDescending(item => item.TotalDeviation)
                .ThenBy(item => item.Username, StringComparer.OrdinalIgnoreCase)
        };

        return query.ToList();
    }

    private List<PlayerTeamStanding> GetSortedTeamStandings()
    {
        var query = standingsSortFilter switch
        {
            StandingsSortFilter.Deviation => teamStandings
                .OrderByDescending(item => item.TotalDeviation)
                .ThenByDescending(item => item.TotalPoints)
                .ThenBy(item => item.Name, StringComparer.OrdinalIgnoreCase),
            _ => teamStandings
                .OrderByDescending(item => item.TotalPoints)
                .ThenByDescending(item => item.TotalDeviation)
                .ThenBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
        };

        return query.ToList();
    }

    private async Task SetHistoryMode(HistoryMode mode)
    {
        historyMode = mode;
        historyErrorMessage = null;

        if (mode == HistoryMode.Player)
        {
            if (userId > 0)
            {
                await LoadUserHistoryAsync(userId);
            }
            else
            {
                pickHistory.Clear();
            }
        }
        else if (selectedHistoryRound.HasValue)
        {
            await LoadRaceHistoryAsync(selectedHistoryRound.Value);
        }
    }

    private void InitializeHistoryRaces(List<Race> races)
    {
        historyRaces.Clear();

        var now = DateTimeOffset.UtcNow;
        foreach (var race in races)
        {
            if (race.Completed || (race.RaceTime.HasValue && race.RaceTime.Value <= now))
            {
                historyRaces.Add(race);
            }
        }

        historyRaces.Sort((a, b) => a.Round.CompareTo(b.Round));
        if (historyRaces.Count > 0)
        {
            selectedHistoryRound = historyRaces[^1].Round;
        }
    }

