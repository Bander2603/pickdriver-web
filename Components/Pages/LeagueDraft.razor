@page "/leagues/{LeagueId:int}/draft"
@implements IAsyncDisposable
@inject ApiClient ApiClient
@inject IAuthSessionStore AuthSessionStore
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Pick Driver</PageTitle>

<div class="league-hub-header">
    <div>
        <h1>@(league?.Name ?? "Liga")</h1>
        <p class="league-hub-subtitle text-muted">Liga activa</p>
    </div>
    <div class="league-hub-header__actions">
        <a class="btn btn-outline-primary" href="/leagues">Volver</a>
    </div>
</div>

@if (!isAuthorized)
{
    <p>Redirigiendo al login...</p>
}
else if (isLoading)
{
    <p><em>Cargando liga...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-warning" role="alert">@errorMessage</div>
}
else if (league is null)
{
    <div class="alert alert-warning" role="alert">No se encontro la liga solicitada.</div>
}
else
{
    <div class="league-hub-meta">
        <div>
            <span class="league-hub-meta__label">Opciones</span>
            <span class="league-hub-meta__value">@LeagueOptionsLabel</span>
        </div>
        <div>
            <span class="league-hub-meta__label">Jugadores</span>
            <span class="league-hub-meta__value">@members.Count/@league.MaxPlayers</span>
        </div>
        <div>
            <span class="league-hub-meta__label">Draft</span>
            <span class="league-hub-meta__value">@DraftProgressLabel</span>
        </div>
    </div>

    <div class="league-hub-nav">
        <button class="league-hub-nav__item @(activeTab == LeagueTab.Draft ? "active" : string.Empty)"
                type="button"
                @onclick="() => SetTab(LeagueTab.Draft)">
            Draft actual
        </button>
        <button class="league-hub-nav__item @(activeTab == LeagueTab.Results ? "active" : string.Empty)"
                type="button"
                @onclick="() => SetTab(LeagueTab.Results)">
            Resultados
        </button>
        <button class="league-hub-nav__item @(activeTab == LeagueTab.History ? "active" : string.Empty)"
                type="button"
                @onclick="() => SetTab(LeagueTab.History)">
            Historial
        </button>
    </div>

    <div class="league-hub-panel">
        @if (activeTab == LeagueTab.Draft)
        {
            <section class="league-hub-card">
                <h2>Draft actual</h2>

                @if (!string.IsNullOrWhiteSpace(draftErrorMessage))
                {
                    <div class="alert alert-warning" role="alert">@draftErrorMessage</div>
                }
                else if (draftRace is null)
                {
                    <p class="text-muted">No hay carreras disponibles para la liga.</p>
                }
                else
                {
                    <div class="league-hub-draft">
                        <div class="league-hub-draft__meta">
                            <div>
                                <p class="league-hub-draft__title">@draftRace.Name</p>
                                <p class="text-muted">Ronda @draftRace.Round · @draftRace.Country</p>
                            </div>
                            <div class="league-hub-draft__tags">
                                <span class="league-hub-tag">@draftRace.CircuitName</span>
                            </div>
                        </div>

                        @if (draftDeadline is not null)
                        {
                            <div class="league-hub-deadlines">
                                <div>
                                    <span class="league-hub-meta__label">Deadline 1</span>
                                    <span class="league-hub-meta__value">@FormatDate(draftDeadline.FirstHalfDeadline)</span>
                                </div>
                                <div>
                                    <span class="league-hub-meta__label">Deadline 2</span>
                                    <span class="league-hub-meta__value">@FormatDate(draftDeadline.SecondHalfDeadline)</span>
                                </div>
                            </div>
                        }

                        @if (raceDraft is not null)
                        {
                            <div class="league-hub-actions">
                                <button class="btn btn-pick" type="button" @onclick="OpenPickModal" disabled="@IsPickDisabled">
                                    @PickActionButtonLabel
                                </button>
                                <button class="btn btn-ban" type="button" @onclick="OpenBanModal" disabled="@IsBanDisabled">
                                    Ban
                                </button>
                                <button class="btn btn-autopick" type="button" @onclick="OpenAutopickModal">
                                    @AutopickActionLabel
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(draftActionMessage))
                            {
                                <div class="alert alert-warning" role="alert">@draftActionMessage</div>
                            }

                            <div class="league-hub-turn">
                                <span class="league-hub-meta__label">Turno actual</span>
                                <span class="league-hub-meta__value">@CurrentPickUserLabel</span>
                            </div>
                        }

                        @if (raceDraft is null)
                        {
                            <p class="text-muted">Aun no se genero el draft para esta carrera.</p>
                        }
                        else if (raceDraft.PickOrder.Count == 0)
                        {
                            <p class="text-muted">No hay orden de picks disponible.</p>
                        }
                        else
                        {
                            <div class="draft-order">
                                <ol class="draft-order__list">
                                    @for (var i = 0; i < raceDraft.PickOrder.Count; i++)
                                    {
                                        var userId = raceDraft.PickOrder[i];
                                        var isCurrent = i == raceDraft.CurrentPickIndex;
                                        var badges = GetPickBadges(i, isCurrent);
                                        var isClickable = isCurrent && !IsPickDisabled;
                                        <li class="draft-order__item @(isCurrent ? "current" : string.Empty) @(isClickable ? "draft-order__item--clickable" : string.Empty)"
                                            @onclick="() => HandleDraftRowClickAsync(isClickable)">
                                            <span class="draft-order__position">@((i + 1).ToString())</span>
                                            <span class="draft-order__name">@GetMemberName(userId)</span>
                                            @if (badges.Count > 0)
                                            {
                                                <div class="draft-order__badges">
                                                    @foreach (var badge in badges)
                                                    {
                                                        <span class="@badge.CssClass">@badge.Label</span>
                                                    }
                                                </div>
                                            }
                                        </li>
                                    }
                                </ol>
                            </div>
                        }

                        @if (league.BansEnabled)
                        {
                            <div class="league-hub-bans">
                                <span class="league-hub-meta__label">Gestion de bans</span>
                                <div class="league-hub-bans__list">
                                    <div class="league-hub-bans__item league-hub-bans__item--header">
                                        <span class="league-hub-bans__name">@BansHeaderLabel</span>
                                        <span class="league-hub-bans__count">Ban por carrera</span>
                                        <span class="league-hub-bans__count">Ban por temporada</span>
                                    </div>
                                    @foreach (var entry in BansUsageEntries)
                                    {
                                        <div class="league-hub-bans__item">
                                            <span class="league-hub-bans__name">@entry.Label</span>
                                            <span class="league-hub-bans__count">@entry.RaceUsed/@entry.RaceTotal</span>
                                            <span class="league-hub-bans__count">@entry.SeasonUsed/@entry.SeasonTotal</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        }
        else if (activeTab == LeagueTab.Results)
        {
            <section class="league-hub-card">
                <div class="league-hub-card__header">
                    <h2>Resultados</h2>
                    <div class="league-hub-filter">
                        <label class="league-hub-filter__label" for="results-filter">Filtro</label>
                        <select id="results-filter" class="form-select form-select-sm league-hub-filter__select" @bind="standingsSortFilter">
                            <option value="@StandingsSortFilter.Points">Puntos</option>
                            <option value="@StandingsSortFilter.Deviation">Desviacion</option>
                        </select>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(standingsErrorMessage))
                {
                    <div class="alert alert-warning" role="alert">@standingsErrorMessage</div>
                }
                else
                {
                    @if (league.TeamsEnabled)
                    {
                        <div class="league-hub-toggle">
                            <button type="button" class="league-hub-toggle__button @(showTeamStandings ? string.Empty : "active")" @onclick="() => SetStandingsMode(false)">
                                Pilotos
                            </button>
                            <button type="button" class="league-hub-toggle__button @(showTeamStandings ? "active" : string.Empty)" @onclick="() => SetStandingsMode(true)">
                                Equipos
                            </button>
                        </div>
                    }

                    @if (!showTeamStandings)
                    {
                        var sortedPlayerStandings = GetSortedPlayerStandings();
                        @if (sortedPlayerStandings.Count == 0)
                        {
                            <p class="text-muted">Sin resultados por ahora.</p>
                        }
                        else
                        {
                            <div class="league-hub-table-wrapper">
                                <table class="league-hub-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Jugador</th>
                                            <th>Puntos</th>
                                            <th>Desviacion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < sortedPlayerStandings.Count; i++)
                                        {
                                            var standing = sortedPlayerStandings[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@standing.Username</td>
                                                <td>@standing.TotalPoints.ToString("0.##")</td>
                                                <td>@standing.TotalDeviation.ToString("0.##")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    else
                    {
                        var sortedTeamStandings = GetSortedTeamStandings();
                        @if (sortedTeamStandings.Count == 0)
                        {
                            <p class="text-muted">Sin resultados por equipos por ahora.</p>
                        }
                        else
                        {
                            <div class="league-hub-table-wrapper">
                                <table class="league-hub-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Equipo</th>
                                            <th>Puntos</th>
                                            <th>Desviacion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < sortedTeamStandings.Count; i++)
                                        {
                                            var standing = sortedTeamStandings[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@standing.Name</td>
                                                <td>@standing.TotalPoints.ToString("0.##")</td>
                                                <td>@standing.TotalDeviation.ToString("0.##")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                }
            </section>
        }
        else if (activeTab == LeagueTab.History)
        {
            <section class="league-hub-card">
                <h2>Historial</h2>

                @if (!string.IsNullOrWhiteSpace(historyErrorMessage))
                {
                    <div class="alert alert-warning" role="alert">@historyErrorMessage</div>
                }
                else
                {
                    <div class="league-hub-toggle">
                        <button type="button" class="league-hub-toggle__button @(historyMode == HistoryMode.Player ? "active" : string.Empty)" @onclick="() => SetHistoryMode(HistoryMode.Player)">
                            Jugador
                        </button>
                        <button type="button" class="league-hub-toggle__button @(historyMode == HistoryMode.Race ? "active" : string.Empty)" @onclick="() => SetHistoryMode(HistoryMode.Race)">
                            Carrera
                        </button>
                    </div>

                    @if (historyMode == HistoryMode.Player)
                    {
                        @if (pickHistory.Count == 0)
                        {
                            <p class="text-muted">No hay picks historicos para tu usuario.</p>
                        }
                        else
                        {
                            <div class="league-hub-table-wrapper">
                                <table class="league-hub-table">
                                    <thead>
                                        <tr>
                                            <th>Carrera</th>
                                            <th>Ronda</th>
                                            <th>Pick</th>
                                            <th>Driver</th>
                                            <th>Puntos</th>
                                            <th>Esperado</th>
                                            <th>Desviacion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var entry in pickHistory)
                                        {
                                            <tr>
                                                <td>@entry.RaceName</td>
                                                <td>@entry.Round</td>
                                                <td>@entry.PickPosition</td>
                                                <td>@entry.DriverName</td>
                                                <td>@entry.Points.ToString("0.##")</td>
                                                <td>@(entry.ExpectedPoints?.ToString("0.##") ?? "-")</td>
                                                <td>@(entry.Deviation?.ToString("0.##") ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    else
                    {
                        @if (historyRaces.Count == 0)
                        {
                            <p class="text-muted">No hay carreras completadas para mostrar historial.</p>
                        }
                        else
                        {
                            <div class="league-hub-history">
                                <label class="form-label" for="history-race">Carrera</label>
                                <select id="history-race"
                                        class="form-select"
                                        value="@selectedHistoryRound"
                                        @onchange="HandleHistoryRaceChanged">
                                    @foreach (var race in historyRaces)
                                    {
                                        <option value="@race.Round">@GetRaceLabel(race)</option>
                                    }
                                </select>
                            </div>

                            @if (racePickRows.Count == 0)
                            {
                                <p class="text-muted">No hay picks para esta carrera.</p>
                            }
                            else
                            {
                                <div class="league-hub-table-wrapper">
                                    <table class="league-hub-table">
                                        <thead>
                                            <tr>
                                                <th>Jugador</th>
                                                <th>Pick</th>
                                                <th>Driver</th>
                                                <th>Puntos</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in racePickRows)
                                            {
                                                <tr>
                                                    <td>@row.Username</td>
                                                    <td>@row.PickPosition</td>
                                                    <td>@row.DriverName</td>
                                                    <td>@row.Points.ToString("0.##")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    }
                }
            </section>
        }
    </div>
}

@if (showPickModal)
{
    <div class="league-hub-modal" role="dialog" aria-modal="true" aria-labelledby="draft-pick-title">
        <div class="league-hub-modal__backdrop" @onclick="ClosePickModal"></div>
        <div class="league-hub-modal__content">
            <div class="league-hub-modal__header">
                <h2 id="draft-pick-title">@PickModalTitle</h2>
                <button type="button" class="league-hub-modal__close" @onclick="ClosePickModal" aria-label="Cerrar">
                    X
                </button>
            </div>

            @if (availablePickDrivers.Count == 0)
            {
                <p class="text-muted">No hay pilotos disponibles para pickear.</p>
            }
            else
            {
                <div class="league-hub-form">
                    <label class="form-label" for="draft-pick-driver">Piloto</label>
                    <select id="draft-pick-driver"
                            class="form-select"
                            value="@selectedPickDriverId"
                            @onchange="HandlePickDriverChanged"
                            disabled="@isSubmittingPick">
                        <option value="">Selecciona un piloto</option>
                        @foreach (var driver in availablePickDrivers)
                        {
                            <option value="@driver.Id">@GetDriverLabel(driver)</option>
                        }
                    </select>
                </div>
            }

            <div class="league-hub-modal__actions">
                <button type="button" class="btn btn-outline-primary" @onclick="ClosePickModal" disabled="@isSubmittingPick">
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmPickAsync" disabled="@IsConfirmPickDisabled">
                    @PickConfirmButtonLabel
                </button>
            </div>
        </div>
    </div>
}

@if (showBanModal)
{
    <div class="league-hub-modal" role="dialog" aria-modal="true" aria-labelledby="draft-ban-title">
        <div class="league-hub-modal__backdrop" @onclick="CloseBanModal"></div>
        <div class="league-hub-modal__content">
            <div class="league-hub-modal__header">
                <h2 id="draft-ban-title">Confirmar ban</h2>
                <button type="button" class="league-hub-modal__close" @onclick="CloseBanModal" aria-label="Cerrar">
                    X
                </button>
            </div>

            @if (lastPickInfo is null)
            {
                <p class="text-muted">No hay pick disponible para banear.</p>
            }
            else
            {
                <p>
                    Vas a banear el pick de <strong>@lastPickInfo.Username</strong> con el piloto
                    <strong>@lastPickInfo.DriverName</strong>.
                </p>
            }

            <div class="league-hub-modal__actions">
                <button type="button" class="btn btn-outline-primary" @onclick="CloseBanModal" disabled="@isSubmittingBan">
                    Cancelar
                </button>
                <button type="button" class="btn btn-outline-danger" @onclick="ConfirmBanAsync" disabled="@IsConfirmBanDisabled">
                    @(isSubmittingBan ? "Baneando..." : "Confirmar ban")
                </button>
            </div>
        </div>
    </div>
}

@if (showAutopickModal)
{
    <div class="league-hub-modal" role="dialog" aria-modal="true" aria-labelledby="draft-autopick-title">
        <div class="league-hub-modal__backdrop" @onclick="CloseAutopickModal"></div>
        <div class="league-hub-modal__content league-hub-modal__content--wide">
            <div class="league-hub-modal__header">
                <h2 id="draft-autopick-title">Configurar autopick</h2>
                <button type="button" class="league-hub-modal__close" @onclick="CloseAutopickModal" aria-label="Cerrar">
                    X
                </button>
            </div>

            @if (isLoadingAutopick)
            {
                <p class="text-muted">Cargando autopick...</p>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(autopickMessage))
                {
                    <div class="alert alert-warning" role="alert">@autopickMessage</div>
                }

                <div class="autopick-grid">
                    <div>
                        <h3>Orden de preferencia</h3>
                        @if (autopickDriverIds.Count == 0)
                        {
                            <p class="text-muted">Aun no hay pilotos en tu lista.</p>
                        }
                        else
                        {
                            <ol class="autopick-list">
                                @for (var i = 0; i < autopickDriverIds.Count; i++)
                                {
                                    var driverId = autopickDriverIds[i];
                                    var index = i;
                                    <li class="autopick-list__item">
                                        <span>@GetDriverName(driverId)</span>
                                        <div class="autopick-list__actions">
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => MoveAutopickDriver(index, -1)" disabled="@(index == 0)">
                                                ↑
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => MoveAutopickDriver(index, 1)" disabled="@(index == autopickDriverIds.Count - 1)">
                                                ↓
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAutopickDriver(index)">
                                                Quitar
                                            </button>
                                        </div>
                                    </li>
                                }
                            </ol>
                        }
                    </div>

                    <div>
                        <h3>Agregar piloto</h3>
                        @if (autopickAvailableDrivers.Count == 0)
                        {
                            <p class="text-muted">No quedan pilotos disponibles para agregar.</p>
                        }
                        else
                        {
                            <div class="league-hub-form">
                                <label class="form-label" for="autopick-add">Piloto</label>
                                <select id="autopick-add"
                                        class="form-select"
                                        value="@autopickAddDriverId"
                                        @onchange="HandleAutopickAddChanged"
                                        disabled="@isSubmittingAutopick">
                                    <option value="">Selecciona un piloto</option>
                                    @foreach (var driver in autopickAvailableDrivers)
                                    {
                                        <option value="@driver.Id">@GetDriverLabel(driver)</option>
                                    }
                                </select>
                            </div>
                            <button type="button" class="btn btn-outline-primary" @onclick="AddAutopickDriver" disabled="@(!autopickAddDriverId.HasValue || isSubmittingAutopick)">
                                Agregar
                            </button>
                        }
                    </div>
                </div>

                <div class="league-hub-modal__actions">
                    <button type="button" class="btn btn-outline-primary" @onclick="CloseAutopickModal" disabled="@isSubmittingAutopick">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="SaveAutopickAsync" disabled="@isSubmittingAutopick">
                        @(isSubmittingAutopick ? "Guardando..." : "Guardar autopick")
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public int LeagueId { get; set; }

    private bool isLoading = true;
    private bool isAuthorized;
    private bool isSubmittingPick;
    private bool isSubmittingBan;
    private bool isSubmittingAutopick;
    private bool isLoadingAutopick;
    private bool showPickModal;
    private bool showBanModal;
    private bool showAutopickModal;
    private int userId;
    private string? errorMessage;
    private string? draftErrorMessage;
    private string? draftActionMessage;
    private string? standingsErrorMessage;
    private string? historyErrorMessage;
    private string? autopickMessage;
    private LeaguePublic? league;
    private Race? draftRace;
    private RaceDraft? raceDraft;
    private DraftResponse? draftState;
    private DraftDeadline? draftDeadline;
    private int? selectedPickDriverId;
    private int? autopickAddDriverId;
    private readonly List<UserPublic> members = new();
    private readonly List<LeagueTeam> teams = new();
    private readonly List<Driver> drivers = new();
    private readonly List<PlayerStanding> playerStandings = new();
    private readonly List<PlayerTeamStanding> teamStandings = new();
    private readonly List<PickHistory> pickHistory = new();
    private readonly List<PickHistory> emptyHistory = new();
    private readonly List<Race> historyRaces = new();
    private readonly List<Race> allRaces = new();
    private readonly List<RacePickRow> racePickRows = new();
    private readonly Dictionary<int, List<PickHistory>> historyCache = new();
    private readonly List<int> autopickDriverIds = new();
    private readonly Dictionary<int, int> bansUsedByTeam = new();
    private readonly Dictionary<int, int> seasonBansUsedByUser = new();
    private bool seasonBansLoaded;
    private bool isLoadingSeasonBans;
    private int? selectedHistoryRound;
    private bool showTeamStandings;
    private StandingsSortFilter standingsSortFilter = StandingsSortFilter.Points;
    private HistoryMode historyMode = HistoryMode.Player;
    private LeagueTab activeTab = LeagueTab.Draft;
    private PickInfo? lastPickInfo;
    private bool hasAutopickSaved;
    private bool autopickLoaded;
    private bool isDraftRefreshing;
    private bool disposed;
    private const int DraftPollingIntervalSeconds = 60;
    private CancellationTokenSource? draftPollingCts;
    private Task? draftPollingTask;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthorized = authState.User.Identity?.IsAuthenticated == true;
        if (!isAuthorized)
        {
            RedirectToLogin();
            isLoading = false;
            return;
        }

        var session = await AuthSessionStore.GetAsync();
        userId = session?.User.Id ?? 0;

        var leaguesResult = await ApiClient.GetAsync<List<LeaguePublic>>("leagues/my", auth: true);
        if (leaguesResult.Success && leaguesResult.Data is not null)
        {
            league = leaguesResult.Data.FirstOrDefault(item => item.Id == LeagueId);
        }
        else
        {
            errorMessage = leaguesResult.ErrorMessage ?? "No se pudo cargar la liga.";
            isLoading = false;
            return;
        }

        if (league is null)
        {
            errorMessage = "No se encontro la liga solicitada.";
            isLoading = false;
            return;
        }

        var membersTask = ApiClient.GetAsync<List<UserPublic>>($"leagues/{LeagueId}/members", auth: true);
        Task<ApiResult<List<LeagueTeam>>>? teamsTask = null;
        if (league.TeamsEnabled)
        {
            teamsTask = ApiClient.GetAsync<List<LeagueTeam>>($"leagues/{LeagueId}/teams", auth: true);
        }

        var standingsTask = ApiClient.GetAsync<List<PlayerStanding>>($"players/standings/players?league_id={LeagueId}", auth: true);
        Task<ApiResult<List<PlayerTeamStanding>>>? teamStandingsTask = null;
        if (league.TeamsEnabled)
        {
            teamStandingsTask = ApiClient.GetAsync<List<PlayerTeamStanding>>($"players/standings/teams?league_id={LeagueId}", auth: true);
        }

        var currentRaceTask = ApiClient.GetAsync<Race>("races/current");
        var upcomingRacesTask = ApiClient.GetAsync<List<Race>>("races/upcoming");
        var allRacesTask = ApiClient.GetAsync<List<Race>>("races");
        var driversTask = ApiClient.GetAsync<List<Driver>>("drivers");

        var tasks = new List<Task> { membersTask, standingsTask, currentRaceTask, upcomingRacesTask, allRacesTask, driversTask };
        if (teamsTask is not null)
        {
            tasks.Add(teamsTask);
        }
        if (teamStandingsTask is not null)
        {
            tasks.Add(teamStandingsTask);
        }

        await Task.WhenAll(tasks);

        var membersResult = await membersTask;
        if (membersResult.Success && membersResult.Data is not null)
        {
            members.AddRange(membersResult.Data.OrderBy(member => member.Username, StringComparer.OrdinalIgnoreCase));
        }

        var allRacesResult = await allRacesTask;
        if (allRacesResult.Success && allRacesResult.Data is not null)
        {
            allRaces.AddRange(allRacesResult.Data);
            InitializeHistoryRaces(allRacesResult.Data);
        }

        var driversResult = await driversTask;
        if (driversResult.Success && driversResult.Data is not null)
        {
            drivers.AddRange(driversResult.Data.Where(driver => driver.Active));
        }

        if (teamsTask is not null)
        {
            var teamsResult = await teamsTask;
            if (teamsResult.Success && teamsResult.Data is not null)
            {
                teams.AddRange(teamsResult.Data);
            }
        }

        var standingsResult = await standingsTask;
        if (standingsResult.Success && standingsResult.Data is not null)
        {
            playerStandings.AddRange(standingsResult.Data.OrderByDescending(item => item.TotalPoints));
        }
        else if (!standingsResult.Success)
        {
            standingsErrorMessage = standingsResult.ErrorMessage ?? "No se pudieron cargar los resultados.";
        }

        if (teamStandingsTask is not null)
        {
            var teamStandingsResult = await teamStandingsTask;
            if (teamStandingsResult.Success && teamStandingsResult.Data is not null)
            {
                teamStandings.AddRange(teamStandingsResult.Data.OrderByDescending(item => item.TotalPoints));
            }
        }

        var currentRaceResult = await currentRaceTask;
        var upcomingRacesResult = await upcomingRacesTask;
        draftRace = ResolveDraftRace(currentRaceResult, upcomingRacesResult);

        if (draftRace is not null)
        {
            await LoadDraftAsync(draftRace.Id);
        }

        if (userId > 0 && members.Any(member => member.Id == userId))
        {
            await LoadUserHistoryAsync(userId);
        }

        if (historyMode == HistoryMode.Race && selectedHistoryRound.HasValue)
        {
            await LoadRaceHistoryAsync(selectedHistoryRound.Value);
        }

        await LoadAutopickSummaryAsync();

        isLoading = false;
        _ = LoadSeasonBansUsageSafelyAsync();
        EnsureDraftPollingStarted();
    }

    private async Task LoadDraftAsync(int raceId)
    {
        draftErrorMessage = null;
        var draftResult = await ApiClient.GetAsync<RaceDraft>($"leagues/{LeagueId}/draft/{raceId}", auth: true);
        if (draftResult.Success && draftResult.Data is not null)
        {
            raceDraft = draftResult.Data;
            NormalizeDraftLists();
            draftState ??= new DraftResponse
            {
                CurrentPickIndex = raceDraft.CurrentPickIndex,
                Status = raceDraft.Status
            };
        }
        else
        {
            draftErrorMessage = draftResult.ErrorMessage ?? "No se pudo cargar el draft.";
        }

        var deadlineResult = await ApiClient.GetAsync<DraftDeadline>($"leagues/{LeagueId}/draft/{raceId}/deadlines", auth: true);
        if (deadlineResult.Success && deadlineResult.Data is not null)
        {
            draftDeadline = deadlineResult.Data;
        }

        UpdateLastPickInfo();
    }

    private void NormalizeDraftLists()
    {
        if (raceDraft is null)
        {
            return;
        }

        var desiredCount = raceDraft.PickOrder.Count;
        if (desiredCount == 0)
        {
            return;
        }

        if (raceDraft.PickedDriverIds.Count < desiredCount)
        {
            while (raceDraft.PickedDriverIds.Count < desiredCount)
            {
                raceDraft.PickedDriverIds.Add(null);
            }
        }
        else if (raceDraft.PickedDriverIds.Count > desiredCount)
        {
            raceDraft.PickedDriverIds.RemoveRange(desiredCount, raceDraft.PickedDriverIds.Count - desiredCount);
        }

        if (raceDraft.BannedDriverIdsByPickIndex.Count < desiredCount)
        {
            while (raceDraft.BannedDriverIdsByPickIndex.Count < desiredCount)
            {
                raceDraft.BannedDriverIdsByPickIndex.Add(null);
            }
        }
        else if (raceDraft.BannedDriverIdsByPickIndex.Count > desiredCount)
        {
            raceDraft.BannedDriverIdsByPickIndex.RemoveRange(desiredCount, raceDraft.BannedDriverIdsByPickIndex.Count - desiredCount);
        }
    }

    private Race? ResolveDraftRace(ApiResult<Race> currentRaceResult, ApiResult<List<Race>> upcomingRacesResult)
    {
        var candidates = new List<Race>();

        if (currentRaceResult.Success && currentRaceResult.Data is not null && !currentRaceResult.Data.Completed)
        {
            candidates.Add(currentRaceResult.Data);
        }

        if (upcomingRacesResult.Success && upcomingRacesResult.Data is not null)
        {
            candidates.AddRange(upcomingRacesResult.Data.Where(race => !race.Completed));
        }

        if (league?.InitialRaceRound is int initialRound)
        {
            candidates = candidates.Where(race => race.Round >= initialRound).ToList();
        }

        return candidates
            .OrderBy(race => race.Round)
            .ThenBy(race => race.RaceTime ?? DateTimeOffset.MaxValue)
            .FirstOrDefault();
    }

