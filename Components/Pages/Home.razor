@page "/"
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Pick Driver</PageTitle>

<AuthorizeView>
    <Authorized>
        <p>Redirigiendo al dashboard...</p>
    </Authorized>
    <NotAuthorized>
        <h1>PickDriver</h1>
        <p class="lead">Inicia sesion o crea una cuenta para empezar a jugar.</p>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" href="login">Iniciar sesion</a>
            <a class="btn btn-outline-secondary" href="register">Crear cuenta</a>
        </div>
        <div class="home-mobile-apps">
            <div class="home-mobile-apps__panel">
                <MobileAppsPanel />
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/dashboard", replace: true);
        }
    }
}
