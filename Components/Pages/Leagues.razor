@page "/leagues"
@inject ApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Ligas</PageTitle>

<div class="leagues-header">
    <div>
        <h1>Ligas</h1>
        <p class="leagues-subtitle text-muted">Gestiona tus ligas y su estado actual.</p>
    </div>
</div>

@if (!isAuthorized)
{
    <p>Redirigiendo al login...</p>
}
else
{
    <div class="leagues-panel">
        @if (isLoading)
        {
            <p class="leagues-empty"><em>Cargando ligas...</em></p>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-warning" role="alert">@errorMessage</div>
        }
        else if (leagues.Count == 0)
        {
            <p class="leagues-empty text-muted">Todavia no estas en ninguna liga.</p>
        }
        else
        {
            <table class="leagues-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Status</th>
                        <th class="leagues-value">Max jugadores</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var league in leagues)
                    {
                        <tr>
                            <td>@league.Name</td>
                            <td><span class="leagues-status">@league.Status</span></td>
                            <td class="leagues-value">@league.MaxPlayers</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private bool isLoading = true;
    private bool isAuthorized;
    private string? errorMessage;
    private readonly List<LeaguePublic> leagues = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthorized = authState.User.Identity?.IsAuthenticated == true;
        if (!isAuthorized)
        {
            RedirectToLogin();
            isLoading = false;
            return;
        }

        var result = await ApiClient.GetAsync<List<LeaguePublic>>("leagues/my", auth: true);
        if (result.Success && result.Data is not null)
        {
            leagues.AddRange(result.Data);
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "No se pudieron cargar las ligas.";
        }

        isLoading = false;
    }

    private void RedirectToLogin()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var target = string.IsNullOrWhiteSpace(relative) ? "/" : "/" + relative;
        var encoded = Uri.EscapeDataString(target);
        NavigationManager.NavigateTo($"/login?returnUrl={encoded}");
    }
}
