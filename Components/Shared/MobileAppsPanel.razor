<section class="mobile-apps-panel">
    <div class="mobile-apps-panel__header">
        <h2 class="mobile-apps-panel__title">@Text["Apps moviles"]</h2>
        <div class="mobile-apps-panel__picker" role="tablist" aria-label="@Text["Seleccionar plataforma movil"]">
            <button type="button"
                    class="mobile-apps-panel__picker-button @(selectedPlatform == MobilePlatform.Ios ? "mobile-apps-panel__picker-button--active" : string.Empty)"
                    role="tab"
                    aria-selected="@(selectedPlatform == MobilePlatform.Ios)"
                    @onclick="() => SetPlatform(MobilePlatform.Ios)">
                iOS
            </button>
            <button type="button"
                    class="mobile-apps-panel__picker-button @(selectedPlatform == MobilePlatform.Android ? "mobile-apps-panel__picker-button--active" : string.Empty)"
                    role="tab"
                    aria-selected="@(selectedPlatform == MobilePlatform.Android)"
                    @onclick="() => SetPlatform(MobilePlatform.Android)">
                Android
            </button>
        </div>
    </div>

    @if (selectedPlatform == MobilePlatform.Ios)
    {
        <p class="mobile-apps-panel__subtitle text-muted">@Text["App iOS nativa en Beta abierta en TestFlight"]</p>
        <div class="mobile-apps-panel__qr">
            <img src="/assets/testflight-ios-qr.svg" alt="@Text["Codigo QR de PickDriver iOS en TestFlight"]" loading="lazy" />
        </div>
        <p class="mobile-apps-panel__note text-muted">@Text["Escanea este codigo para instalar la beta."]</p>
    }
    else
    {
        <p class="mobile-apps-panel__subtitle text-muted">@Text["App Android nativa en beta cerrada"]</p>
        <p class="mobile-apps-panel__note mobile-apps-panel__note--android text-muted">
            @Text["Unete al"]
            <a class="mobile-apps-panel__testers-link" href="https://groups.google.com/g/pickdriver-testers">@Text["grupo de testers"]</a>
            @Text["y descarga la app escaneando este codigo QR."]
        </p>
        <div class="mobile-apps-panel__qr">
            <img src="/assets/play-store-android-qr.svg" alt="@Text["Codigo QR de PickDriver Android en Google Play"]" loading="lazy" />
        </div>
        <p class="mobile-apps-panel__note text-muted">@Text["Escanea este codigo para abrir la app en Google Play."]</p>
    }
</section>

@code {
    private MobilePlatform selectedPlatform = MobilePlatform.Ios;

    private void SetPlatform(MobilePlatform platform)
    {
        selectedPlatform = platform;
    }

    private enum MobilePlatform
    {
        Ios,
        Android
    }
}
